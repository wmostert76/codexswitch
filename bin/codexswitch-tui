@dataclass(frozen=True)
class Selection:
    provider: str = "openai"
    account: str | None = None
    model: str | None = None
    reasoning: str | None = None


class FKey(Static):
    """Clickable function-key segment."""

    def __init__(
        self,
        key: str,
        compact_label: str,
        full_label: str,
        action: str,
    ) -> None:
        super().__init__(classes="fkey", id=f"fkey-{action}", markup=True)
        self.key_name = key
        self.compact_label = compact_label
        self.full_label = full_label
        self.fkey_action = action
        self.set_compact(True)

    def set_compact(self, compact: bool) -> None:
        label = self.compact_label if compact else self.full_label
        self.update(f"[reverse bold]{self.key_name}[/] {label}")


def splash_line(text: str) -> str:
    return text.center(BACKEND["ASCII_LOGO_WIDTH"])


class SplashScreen(ModalScreen[bool]):
    BINDINGS = [
        Binding("enter", "continue", "Continue", show=False),
        Binding("escape", "continue", "Continue", show=False),
        Binding("space", "continue", "Continue", show=False),
    ]

    def compose(self) -> ComposeResult:
        yield Static(
            f"""[bold #000087]{BACKEND['BRAND_BANNER']}[/]

[bold #000087]{splash_line(f"CodexSwitch Commander v{BACKEND['VERSION']}")}[/]
[black]{splash_line(BACKEND['CREDITS_OWNER'])}[/]
[black]{splash_line(BACKEND['CREDITS_AI'])}[/]

[black]{splash_line("Enter / Space / Esc / Click to continue")}[/]
""",
            id="splash-dialog",
            markup=True,
        )

    def action_continue(self) -> None:
        self.dismiss(True)

    def on_click(self, event: Click) -> None:
        self.dismiss(True)


class HelpScreen(ModalScreen[None]):
    BINDINGS = [
        Binding("escape", "dismiss", "Close", show=False),
        Binding("f1", "dismiss", "Close", show=False),
        Binding("question_mark", "dismiss", "Close", show=False),
    ]

    def compose(self) -> ComposeResult:
        with VerticalScroll(id="help-dialog"):
            yield Static(
                """[bold #000087]CODEXSWITCH COMMANDER HELP[/]

[black]WORKFLOW[/]  Providers → Models → Reasoning
  ↑↓ Move · Home/End First/last · PgUp/PgDn Page
  ←→ or Tab/Shift+Tab Switch panel
  Enter Next panel / start from Reasoning
  / Filter models · Esc Close/cancel/reset

[black]COMMANDS[/]
  F1/? Help · F2/p Providers · F3/m Models
  F4/t Reasoning · F5/r Refresh · F6/a Apply
  F7/l Auth · F8/s Status · F9/c Start · F10/q Quit

[black]MARKERS[/]  ● Active   ◆ Pending   ○ Other

[black]LAUNCH[/]  Enter from Reasoning or F9 applies and starts Codex
  with sandbox bypass and search. F6 only applies.

[black]ABOUT[/]
"""
                + f"[bold #000087]{BACKEND['BRAND_BANNER']}[/]\n\n"
                + f"[bold #000087]CodexSwitch Commander v{BACKEND['VERSION']}[/]\n"
                + f"[black]{BACKEND['CREDITS_OWNER']}[/]\n"
                + f"[black]{BACKEND['CREDITS_AI']}[/]\n\n"
                + "[black]Press Escape, F1, ? or click outside to close.[/]",
                id="help-content",
                markup=True,
            )

    def on_click(self, event: Click) -> None:
        if event.widget.id != "help-content":
            self.dismiss()


class ConfirmQuitScreen(ModalScreen[bool]):
    BINDINGS = [
        Binding("enter", "confirm", "Quit", show=False),
        Binding("escape", "cancel", "Cancel", show=False),
    ]

    def compose(self) -> ComposeResult:
        with Vertical(classes="modal-dialog", id="quit-dialog"):
            yield Label("QUIT CODEXSWITCH?", classes="modal-title")
            yield Static(
                "Pending changes have not been applied.\n"
                "Press Enter to quit or Escape to continue.",
                classes="modal-copy",
            )

    def action_confirm(self) -> None:
        self.dismiss(True)

    def action_cancel(self) -> None:
        self.dismiss(False)


