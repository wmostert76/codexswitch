        Binding("m", "models", "Models", show=False),
        Binding("f4", "reasoning", "Reasoning", show=False),
        Binding("t", "reasoning", "Reasoning", show=False),
        Binding("f5", "refresh", "Refresh", show=False),
        Binding("r", "refresh", "Refresh", show=False),
        Binding("f6", "apply", "Apply", show=False),
        Binding("a", "apply", "Apply", show=False),
        Binding("f7", "auth", "Auth", show=False),
        Binding("l", "auth", "Auth", show=False),
        Binding("f8", "status", "Status", show=False),
        Binding("s", "status", "Status", show=False),
        Binding("f9", "codex", "Start", show=False),
        Binding("c", "codex", "Start", show=False),
