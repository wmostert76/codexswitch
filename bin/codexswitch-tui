            "ctrl+q",
            "request_quit",
            "Quit",
            show=False,
            priority=True,
        ),
        Binding("slash", "search_models", "Search", show=False),
        Binding("left", "previous_panel", "Previous panel", show=False),
        Binding("right", "next_panel", "Next panel", show=False),
        Binding("escape", "cancel", "Cancel", show=False),
    ]

    def __init__(
        self,
        backend: dict[str, Any] | None = None,
        state_path: str | Path | None = None,
        refresh_on_start: bool = True,
    ) -> None:
        super().__init__()
        self.backend = backend or BACKEND
        switch_home = Path(self.backend.get("SWITCH_HOME", Path.home() / ".config/codexswitch"))
        cache_enable = self.backend.get("enable_vault_session_cache")
        if cache_enable:
            try:
                cache_enable(switch_home)
            except Exception:
                pass
        self.state_path = Path(state_path) if state_path else switch_home / "tui-state.json"
        self.refresh_on_start = refresh_on_start

        self.active = Selection()
        self.draft = Selection()
        self.runtime_drift = False
        self.launch_codex = False
        self.loading_sources = False
        self.loading_models = False
        self.loading_reasoning = False
        self.operation_busy = False
        self.busy_providers: set[str] = set()
        self.catalog_ready: set[str] = set()
        self.model_filter_query = ""
        self.openrouter_sort_column = "model"
        self.openrouter_sort_descending = False
        self.search_has_no_results = False
        self.unavailable_draft = False
        self.modal_origin: str | None = None
        self.small_screen_focus: str | None = None
        self.too_small = False
        self.last_focus_id: str | None = None
        self.status_hint_held = False
        self.vault_label = "LOCAL"
        self.proxy_states: dict[str, bool | None] = {"unified": None}
        self.backend_worker_lock = asyncio.Lock()

        self.catalogs: dict[str, dict[str, dict]] = {
            "openai": dict(self.backend.get("OPENAI_FALLBACK_CATALOG", {})),
            "azure": {},
            "opencode-go": dict(self.backend.get("OPENCODE_GO_FALLBACK_CATALOG", {})),
            "openrouter": {},
        }
        self.model_lists: dict[str, list[str]] = {
            "openai": list(self.backend.get("OPENAI_FALLBACK_MODELS", ["gpt-5.5"])),
            "azure": list(self.backend.get("AZURE_MODELS", ["gpt-5.6-sol"])),
            "opencode-go": list(self.catalogs["opencode-go"]),
            "openrouter": list(
                self.backend.get("OPENROUTER_FALLBACK_MODELS", ["openrouter/auto"])
            ),
        }

    @property
    def provider(self) -> str:
        return self.draft.provider

    @provider.setter
    def provider(self, value: str) -> None:
        self.draft = replace(self.draft, provider=value)

    @property
    def account(self) -> str | None:
        return self.draft.account

    @account.setter
    def account(self, value: str | None) -> None:
        self.draft = replace(self.draft, account=value)

    @property
    def model(self) -> str | None:
        return self.draft.model

    @model.setter
    def model(self, value: str | None) -> None:
        self.draft = replace(self.draft, model=value)

    @property
    def catalog(self) -> dict[str, dict]:
        return self.catalogs["opencode-go"]

    @catalog.setter
    def catalog(self, value: dict[str, dict]) -> None:
        self.catalogs["opencode-go"] = value

    @property
    def openai_metadata(self) -> dict[str, dict]:
        return self.catalogs["openai"]

    @openai_metadata.setter
    def openai_metadata(self, value: dict[str, dict]) -> None:
        self.catalogs["openai"] = value

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        with Horizontal(id="workspace"):
            with Vertical(classes="pane", id="source-pane"):
                yield Label("┤ PROVIDERS ├", classes="pane-title", id="source-title")
                yield OptionList(id="sources")
            with Vertical(classes="pane", id="model-pane"):
                yield Label("┤ MODELS ├", classes="pane-title", id="model-title")
                with Horizontal(id="openrouter-model-columns"):
                    yield Static("MODEL", id="model-sort-model")
                    yield Static("INPUT     OUTPUT", id="model-sort-cost")
                yield Input(
                    placeholder="Search models…",
                    id="model-filter",
                )
                yield OptionList(id="models")
            with Vertical(classes="pane", id="reason-box"):
                yield Label("┤ REASONING ├", classes="pane-title")
                yield OptionList(id="reasoning")
        with Vertical(id="detail-box"):
            yield Label("┤ MODEL DETAILS ├", classes="detail-title")
            yield Static("", id="model-detail")
        yield Static("", id="proxy-status")
        yield Static("Ready", id="status")
        with Horizontal(id="buttonbar"):
            for key, compact, full, action in FUNCTION_KEYS:
                yield FKey(key, compact, full, action)
        yield Static("", id="size-warning")

    def on_mount(self) -> None:
        self.active = self.read_active_selection()
        self.draft = self.active
        if self.active.model:
            models = self.model_lists.setdefault(self.active.provider, [])
            if self.active.model not in models:
                models.insert(0, self.active.model)
        self.load_sources()
        self.load_models()
        self.query_one("#sources", OptionList).focus()
        self.update_responsive_ui(self.size.width, self.size.height)
        self.render_proxy_statuses()
        self.update_status_hint()
        if self.should_show_splash():
            self.push_screen(SplashScreen(), self.on_splash_dismissed)
        if self.refresh_on_start:
            self.start_startup_refresh()

    # ---------- State and safe backend access ----------

    def safe_call(self, name: str, default: Any, *args) -> Any:
        function = self.backend.get(name)
        if function is None:
            return default
        try:
            return function(*args)
        except (Exception, SystemExit):
            return default

    def read_backend_json(self, path: Path | None, default: Any) -> Any:
        if path is None:
            return default
        return self.safe_call("read_json", default, path, default)

    def read_active_selection(self) -> Selection:
        switch_path = self.backend.get("SWITCH_CONFIG")
        state = self.read_backend_json(switch_path, {})
        if not isinstance(state, dict):
            state = {}
        codex_state = self.safe_call("codex_config_state", {})
        if not isinstance(codex_state, dict):
            codex_state = {}

        saved_provider = state.get("provider", "openai")
        runtime_provider = codex_state.get("model_provider")
        provider = runtime_provider or saved_provider
        if provider not in PROVIDERS:
            provider = saved_provider if saved_provider in PROVIDERS else "openai"
        saved_model = state.get("model")
        runtime_model = codex_state.get("model")
        model = runtime_model or saved_model
        saved_reasoning = state.get("reasoning_effort")
        runtime_reasoning = codex_state.get("model_reasoning_effort")
        reasoning = (
            runtime_reasoning
            if "model_reasoning_effort" in codex_state
            else saved_reasoning
        )

        current_account = (
            self.current_openai_account() if provider == "openai" else None
        )
        saved_account = state.get("openai_account") if provider == "openai" else None
        account = current_account or saved_account
        self.runtime_drift = any(
            runtime_value != saved_value
            for runtime_value, saved_value, runtime_key, saved_key in (
                (runtime_provider, saved_provider, "model_provider", "provider"),
                (runtime_model, saved_model, "model", "model"),
                (
                    runtime_reasoning,
                    saved_reasoning,
                    "model_reasoning_effort",
                    "reasoning_effort",
                ),
            )
            if runtime_key in codex_state or saved_key in state
        )
        if (
            provider == "openai"
            and saved_account is not None
            and saved_account != current_account
        ):
            self.runtime_drift = True
        return Selection(provider, account, model, reasoning)

    def current_openai_account(self) -> str | None:
        if self.backend.get("CODEX_HOME") is None:
            return None
        auth_path = Path(self.backend["CODEX_HOME"]) / "auth.json"
        auth = self.read_backend_json(auth_path, {})
        return self.safe_call("openai_auth_email", None, auth)

    def selection_is_dirty(self) -> bool:
        return self.draft != self.active or self.runtime_drift

    def selection_label(self, selection: Selection | None = None) -> str:
        selection = selection or self.draft
        parts = [selection.provider, selection.model or "no model"]
        if selection.reasoning:
            parts.append(selection.reasoning)
        if selection.provider == "openai" and selection.account:
            parts.append(f"acct: {selection.account}")
        return " / ".join(parts)

    def status_selection_label(self, selection: Selection | None = None) -> str:
        selection = selection or self.draft
        if self.size.width >= 120:
            return self.selection_label(selection)
        return self.selection_label(replace(selection, account=None))

    @staticmethod
    def marker(active: bool, draft: bool) -> str:
        if draft and not active:
            return "◆"
        if active:
            return "●"
        return "○"

    def should_show_splash(self) -> bool:
        try:
            data = json.loads(self.state_path.read_text())
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            return True
        return data.get("splash_version") != self.backend.get("VERSION", BACKEND["VERSION"])

    def mark_splash_seen(self) -> None:
        version = self.backend.get("VERSION", BACKEND["VERSION"])
        writer = self.backend.get("write_json")
        if writer is not None:
            try:
                writer(self.state_path, {"splash_version": version})
                return
            except (Exception, SystemExit):
                pass
        try:
            self.state_path.parent.mkdir(parents=True, exist_ok=True)
            temporary = self.state_path.with_name(f".{self.state_path.name}.{os.getpid()}.tmp")
            temporary.write_text(json.dumps({"splash_version": version}, indent=2) + "\n")
            os.replace(temporary, self.state_path)
        except OSError:
            pass

    def on_splash_dismissed(self, result: bool | None) -> None:
        self.mark_splash_seen()
        self.restore_modal_focus()

    # ---------- Option construction and selection ----------

    def plain_option(
        self,
        marker: str,
        label: str,
        *,
        indent: str = "",
        bold: bool = False,
        suffix: str = "",
    ) -> Text:
        text = Text(no_wrap=True, overflow="ellipsis")
        text.append(f"{indent}{marker} ")
        text.append(label, style="bold" if bold else None)
        if suffix:
            text.append(suffix)
        return text

    def source_options(self) -> list[Option]:
        options: list[Option] = []
        accounts = self.safe_call("openai_accounts", [])
        if not isinstance(accounts, list):
            accounts = []
        for provider in PROVIDERS:
            active = self.active.provider == provider
            draft = self.draft.provider == provider
            options.append(
                Option(
                    self.plain_option(
                        self.marker(active, draft),
                        PROVIDER_LABELS[provider].upper(),
                        bold=True,
                    ),
                    id=f"provider:{provider}",
                )
            )
            if provider == "openai":
                for email in accounts:
                    active_account = active and self.active.account == email
                    draft_account = draft and self.draft.account == email
                    options.append(
                        Option(
                            self.plain_option(
                                self.marker(active_account, draft_account),
                                str(email),
                                indent="  ",
                            ),
                            id=f"account:{email}",
                        )
                    )
                options.append(
                    Option(
                        Text("  + Add account", no_wrap=True, overflow="ellipsis"),
                        id="action:add-openai-account",
                    )
                )
        return options

    @staticmethod
    def source_target_id(selection: Selection) -> str:
        if selection.provider == "openai" and selection.account:
            return f"account:{selection.account}"
        return f"provider:{selection.provider}"

    def load_sources(self, target_id: str | None = None) -> None:
        sources = self.query_one("#sources", OptionList)
        current_id = target_id
        if current_id is None and sources.highlighted_option is not None:
            current_id = sources.highlighted_option.id
        if current_id is None:
            current_id = (
                f"account:{self.draft.account}"
                if self.draft.provider == "openai" and self.draft.account
                else f"provider:{self.draft.provider}"
            )
        self.loading_sources = True
        try:
            sources.set_options(self.source_options())
            for index, option in enumerate(sources.options):
                if option.id == current_id:
                    sources.highlighted = index
                    break
            else:
                for index, option in enumerate(sources.options):
                    if option.id == f"provider:{self.draft.provider}":
                        sources.highlighted = index
                        break
        finally:
            self.loading_sources = False

    def update_source_markers(self) -> None:
        sources = self.query_one("#sources", OptionList)
        highlighted_id = sources.highlighted_option.id if sources.highlighted_option else None
        replacement = self.source_options()
        if len(replacement) != len(sources.options):
            self.load_sources(highlighted_id)
            return
        for index, option in enumerate(replacement):
            sources.replace_option_prompt_at_index(index, option.prompt)

    def provider_default_model(self, provider: str, models: list[str]) -> str | None:
        if not models:
            return None
        if self.active.provider == provider and self.active.model in models:
            return self.active.model
        defaults = {
            "openai": "gpt-5.5",
            "azure": self.backend.get("AZURE_MODEL", "gpt-5.6-sol"),
            "opencode-go": self.backend.get("DEFAULT_OPENCODE_MODEL"),
            "openrouter": (
                self.backend.get("OPENROUTER_FALLBACK_MODELS", [None]) or [None]
            )[0],
        }
        default = defaults.get(provider)
        return default if default in models else models[0]

    def model_display_name(self, provider: str, model: str) -> str:
        meta = self.catalogs.get(provider, {}).get(model, {})
        if not isinstance(meta, dict):
            return model
        return str(meta.get("display_name") or meta.get("name") or model)

    def openrouter_prices(self, model: str) -> tuple[Decimal | None, Decimal | None]:
        meta = self.catalogs.get("openrouter", {}).get(model, {})
        pricing = meta.get("pricing", {}) if isinstance(meta, dict) else {}
        if not isinstance(pricing, dict):
            return None, None

        def per_million(value: Any) -> Decimal | None:
            try:
                price = Decimal(str(value))
            except (InvalidOperation, TypeError, ValueError):
                return None
            return price * Decimal(1_000_000) if price >= 0 else None

        return per_million(pricing.get("prompt")), per_million(
            pricing.get("completion")
        )

    @staticmethod
    def price_display(value: Decimal | None) -> str:
        if value is None:
            return "$--.--"
        return f"${value:.2f}"

    def openrouter_cost_display(self, model: str) -> tuple[str, str]:
        prompt, completion = self.openrouter_prices(model)
        return self.price_display(prompt), self.price_display(completion)

    def openrouter_codex_compatibility(self, model: str) -> tuple[str, str]:
        statuses = self.backend.get("OPENROUTER_CODEX_COMPATIBILITY", {})
        descriptions = self.backend.get(
            "OPENROUTER_CODEX_COMPATIBILITY_DESCRIPTIONS", {}
        )
        if not isinstance(statuses, dict) or not isinstance(descriptions, dict):
            return "", ""
        status = statuses.get(model)
        if not isinstance(status, str):
            return "", ""
        description = descriptions.get(status)
        return status, str(description) if description else status

    def sorted_model_ids(self, provider: str, models: list[str]) -> list[str]:
        if provider != "openrouter":
            return models
        if self.openrouter_sort_column == "model":
            return sorted(
                models,
                key=str.casefold,
                reverse=self.openrouter_sort_descending,
            )

        priced: list[tuple[Decimal, Decimal, str]] = []
        missing: list[str] = []
        for model in models:
            prompt, completion = self.openrouter_prices(model)
            if prompt is None or completion is None:
                missing.append(model)
            else:
                priced.append((prompt, completion, model))
        priced.sort(
            key=lambda item: (item[0] + item[1], item[0], item[1], item[2].casefold()),
            reverse=self.openrouter_sort_descending,
        )
        return [item[2] for item in priced] + sorted(missing, key=str.casefold)

    def update_openrouter_model_controls(self, provider: str) -> None:
        is_openrouter = provider == "openrouter"
        columns = self.query_one("#openrouter-model-columns", Horizontal)
        columns.styles.display = "block" if is_openrouter else "none"
        self.query_one("#model-title", Label).update(
            "┤ MODELS · USD / 1M TOKENS ├" if is_openrouter else "┤ MODELS ├"
        )
        field = self.query_one("#model-filter", Input)
        field.placeholder = (
            "Search…  C: ! limited · x failed · ~ rate-limited"
            if is_openrouter
            else "Filter model ID or name…"
        )
        if is_openrouter:
            field.styles.display = "block"
        elif not field.has_focus and not self.model_filter_query:
            field.styles.display = "none"

        direction = "▼" if self.openrouter_sort_descending else "▲"
        model_label = "C MODEL"
        cost_label = "INPUT     OUTPUT"
        if self.openrouter_sort_column == "model":
            model_label += f" {direction}"
        else:
            cost_label = f"INPUT {direction}   OUTPUT"
        model_header = self.query_one("#model-sort-model", Static)
        cost_header = self.query_one("#model-sort-cost", Static)
        model_header.update(model_label)
        cost_header.update(cost_label)
        model_header.styles.color = (
            "#ffff00" if self.openrouter_sort_column == "model" else "#5fd7ff"
        )
        cost_header.styles.color = (
            "#ffff00" if self.openrouter_sort_column == "cost" else "#5fd7ff"
        )

    def model_option_prompt(
        self, marker: str, provider: str, model: str, suffix: str = ""
    ) -> Text:
        if provider != "openrouter":
            return self.plain_option(marker, model, suffix=suffix)
        prompt_price, completion_price = self.openrouter_cost_display(model)
        compatibility, _description = self.openrouter_codex_compatibility(model)
        compatibility_marker, compatibility_style = OPENROUTER_CODEX_STATUS_MARKERS.get(
            compatibility, (" ", "")
        )
        # Reserve two cells for the marker and two for OptionList's scrollbar,
        # plus a Codex compatibility marker, so the final price never gets
        # ellipsized at the 80-column minimum.
        available = max(8, self.query_one("#models", OptionList).size.width - 23)
        label = model if len(model) <= available else f"{model[: available - 1]}…"
        text = Text(no_wrap=True, overflow="ellipsis")
        text.append(f"{marker} ")
        text.append(compatibility_marker, style=compatibility_style)
        text.append(f" {label:<{available}}")
        text.append(f"{prompt_price:>8} {completion_price:>8}")
        if suffix:
            text.append(suffix)
        return text

    def filtered_model_ids(self, provider: str, models: list[str]) -> list[str]:
        query = self.model_filter_query.casefold().strip()
        if not query:
            return models
        return [
            model
            for model in models
            if query in model.casefold()
            or query in self.model_display_name(provider, model).casefold()
        ]

    def load_models(self, preserve_missing: bool = False) -> None:
        provider = self.draft.provider
        self.update_openrouter_model_controls(provider)
        canonical = list(dict.fromkeys(self.model_lists.get(provider, [])))
        draft_model = self.draft.model
        self.unavailable_draft = False
        if draft_model not in canonical:
            if draft_model and preserve_missing:
                self.unavailable_draft = self.active.model != draft_model
            else:
                draft_model = self.provider_default_model(provider, canonical)
                self.draft = replace(self.draft, model=draft_model, reasoning=None)

        visible_base = list(canonical)
        for special in (
            self.active.model if self.active.provider == provider else None,
            draft_model,
        ):
            if special and special not in visible_base:
                visible_base.insert(0, special)
        visible = self.sorted_model_ids(
            provider, self.filtered_model_ids(provider, visible_base)
        )

        preview_model = draft_model
        if visible and draft_model not in visible:
            preview_model = visible[0]
            draft_model = preview_model
            self.draft = replace(self.draft, model=draft_model, reasoning=None)

        self.search_has_no_results = bool(self.model_filter_query and not visible)

        options: list[Option] = []
        selected_index = 0
        for index, model in enumerate(visible):
            active = self.active.provider == provider and self.active.model == model
            draft = self.draft.model == model
            unavailable = model not in canonical and provider in self.catalog_ready
            suffix = " [unavailable]" if unavailable else ""
            options.append(
                Option(
                    self.model_option_prompt(
                        self.marker(active, draft),
                        provider,
                        model,
                        suffix=suffix,
                    ),
                    id=f"model:{model}",
                )
            )
            if model == preview_model:
                selected_index = index
        if not options:
            options = [Option(Text("  No matching models"), id=None, disabled=True)]

        model_list = self.query_one("#models", OptionList)
        self.loading_models = True
        try:
            model_list.set_options(options)
            if visible:
                model_list.highlighted = selected_index
        finally:
            self.loading_models = False
        self.update_reasoning()
        self.update_details()

    def update_model_markers(self) -> None:
        models = self.query_one("#models", OptionList)
        provider = self.draft.provider
        for index, option in enumerate(models.options):
            if not option.id:
                continue
            model = option.id.split(":", 1)[1]
            active = self.active.provider == provider and self.active.model == model
            draft = self.draft.model == model
            unavailable = (
                model not in self.model_lists.get(provider, [])
                and provider in self.catalog_ready
            )
            models.replace_option_prompt_at_index(
                index,
                self.model_option_prompt(
                    self.marker(active, draft),
                    provider,
                    model,
                    suffix=" [unavailable]" if unavailable else "",
                ),
            )

    def reasoning_choices(self) -> list[tuple[str, str | None]]:
        provider = self.draft.provider
        model = self.draft.model
        if not model:
            return [("Model default", None)]
        if provider == "azure":
            choices = self.backend.get("AZURE_REASONING_CHOICES", [])
            return [
                (str(label), str(effort))
                for label, effort in choices
                if label and effort
            ] or [("Model default", None)]
        meta = self.catalogs.get(provider, {}).get(model, {})
        if not isinstance(meta, dict):
            meta = {}
        choices: list[tuple[str, str | None]] = []
        if provider == "openai":
            levels = meta.get("supported_reasoning_levels", [])
            if isinstance(levels, list):
                for item in levels:
                    effort = item.get("effort") if isinstance(item, dict) else None
                    if isinstance(effort, str):
                        choices.append((effort, effort))
        elif provider == "opencode-go":
            variants = meta.get("variants", {})
            if isinstance(variants, dict):
                if set(variants) == {"none", "thinking"}:
                    choices = [("thinking", "high"), ("none", "none")]
                else:
                    for variant in variants:
                        effort = "xhigh" if variant == "max" else variant
                        if effort in {
                            "none",
                            "minimal",
                            "low",
                            "medium",
                            "high",
                            "xhigh",
                        }:
                            choices.append((variant, effort))
        elif provider == "openrouter":
            reasoning = meta.get("reasoning", {})
            efforts = (
                reasoning.get("supported_efforts", [])
                if isinstance(reasoning, dict)
                else []
            )
            seen: set[str] = set()
            if isinstance(efforts, list):
                for raw_effort in efforts:
                    if not isinstance(raw_effort, str):
                        continue
                    if raw_effort == "max" and "xhigh" in efforts:
                        continue
                    effort = "xhigh" if raw_effort == "max" else raw_effort
                    if effort not in seen:
                        choices.append((raw_effort, effort))
                        seen.add(effort)
        if choices:
            return choices
        reasoning = meta.get("reasoning", {}) if isinstance(meta, dict) else {}
        if isinstance(reasoning, dict) and reasoning.get("mandatory"):
            return [("Model managed", None)]
        if (
            self.active.provider == provider
            and self.active.model == model
            and self.active.reasoning
        ):
            return [(self.active.reasoning, self.active.reasoning)]
        return [("Model default", None)]

    def default_reasoning(
        self, choices: list[tuple[str, str | None]]
    ) -> str | None:
        values = {value for _, value in choices}
        if None in values:
            return None
        provider = self.draft.provider
        model = self.draft.model
        if provider == "azure":
            default = self.backend.get("AZURE_DEFAULT_REASONING_EFFORT", "low")
            return str(default) if default in values else choices[0][1]
        meta = self.catalogs.get(provider, {}).get(model or "", {})
        default = None
        if isinstance(meta, dict):
            default = meta.get("default_reasoning_level") or meta.get(
                "default_effort"
            )
            reasoning = meta.get("reasoning", {})
            if default is None and isinstance(reasoning, dict):
                default = reasoning.get("default_effort")
        if default == "max":
            default = "xhigh"
        if default is None:
            for preferred in ("medium", "high", "xhigh", "low", "none"):
                if preferred in values:
                    default = preferred
                    break
        return str(default) if default in values else choices[0][1]

    def update_reasoning(self) -> None:
        choices = self.reasoning_choices()
        values = {value for _, value in choices}
        current = self.draft.reasoning
        if current not in values:
            if (
                self.active.provider == self.draft.provider
                and self.active.model == self.draft.model
                and self.active.reasoning in values
            ):
                current = self.active.reasoning
            else:
                current = self.default_reasoning(choices)
            self.draft = replace(self.draft, reasoning=current)

        options: list[Option] = []
        selected_index = 0
        same_active_model = (
            self.active.provider == self.draft.provider
            and self.active.model == self.draft.model
        )
        for index, (label, value) in enumerate(choices):
            active = same_active_model and self.active.reasoning == value
            draft = self.draft.reasoning == value
            option_value = DEFAULT_REASONING_VALUE if value is None else value
            options.append(
                Option(
                    self.plain_option(self.marker(active, draft), label),
                    id=f"reason:{option_value}",
                )
            )
            if draft:
                selected_index = index
        reasoning = self.query_one("#reasoning", OptionList)
        self.loading_reasoning = True
        try:
            reasoning.set_options(options)
            reasoning.highlighted = selected_index
        finally:
            self.loading_reasoning = False

    def update_reasoning_markers(self) -> None:
        try:
            reasoning = self.query_one("#reasoning", OptionList)
        except NoMatches:
            return
        same_active_model = (
            self.active.provider == self.draft.provider
            and self.active.model == self.draft.model
        )
        for index, option in enumerate(reasoning.options):
            if not option.id:
                continue
            raw = option.id.split(":", 1)[1]
            value = None if raw == DEFAULT_REASONING_VALUE else raw
            label = str(option.prompt).lstrip(" ●◆○")
            active = same_active_model and self.active.reasoning == value
            draft = self.draft.reasoning == value
            reasoning.replace_option_prompt_at_index(
                index,
                self.plain_option(self.marker(active, draft), label),
            )

    # ---------- Details and status ----------

    @staticmethod
    def token_value(*values) -> int | str:
        for value in values:
            if isinstance(value, int):
                return value
            if isinstance(value, str) and value.isdigit():
                return int(value)
        return "?"

    @staticmethod
    def token_display(value: int | str) -> str:
        return f"{value:,}" if isinstance(value, int) else str(value)

    def auth_summary(self, provider: str) -> str:
        if provider == "openai":
            return self.draft.account or "not detected"
        function = {
            "azure": "azure_credentials_present",
            "opencode-go": "opencode_go_key_present",
            "openrouter": "openrouter_key_present",
        }.get(provider)
        return "ok" if self.safe_call(function, False) else "missing"

    def update_details(self) -> None:
        try:
            detail = self.query_one("#model-detail", Static)
        except NoMatches:
            return
        model = self.draft.model
        provider = self.draft.provider
        if not model:
            detail.update(Text("No model available"))
            return
        meta = self.catalogs.get(provider, {}).get(model, {})
        if not isinstance(meta, dict):
            meta = {}
        name = self.model_display_name(provider, model)
        context = self.token_value(
            meta.get("context_window"),
            meta.get("context_length"),
            meta.get("max_context_tokens"),
            (meta.get("limit") or {}).get("context")
            if isinstance(meta.get("limit"), dict)
            else None,
            (meta.get("limit") or {}).get("input")
            if isinstance(meta.get("limit"), dict)
            else None,
        )
        output = self.token_value(
            meta.get("max_output_tokens"),
            meta.get("max_completion_tokens"),
            meta.get("max_tokens"),
            (meta.get("limit") or {}).get("output")
            if isinstance(meta.get("limit"), dict)
            else None,
        )
        capabilities = meta.get("capabilities", {})
        architecture = meta.get("architecture", {})
        modalities: list[str] = []
        if isinstance(capabilities, dict) and isinstance(capabilities.get("input"), dict):
            modalities = [
                str(name)
                for name, enabled in capabilities["input"].items()
                if enabled
            ]
        elif isinstance(architecture, dict) and isinstance(
            architecture.get("input_modalities"), list
        ):
            modalities = [str(value) for value in architecture["input_modalities"]]
        elif isinstance(meta.get("input_modalities"), list):
            modalities = [str(value) for value in meta["input_modalities"]]
        if not modalities:
            modalities = ["text"]
        supported_parameters = meta.get("supported_parameters", [])
        if isinstance(capabilities, dict) and "toolcall" in capabilities:
            tools = "yes" if capabilities.get("toolcall") else "no"
        elif isinstance(supported_parameters, list) and any(
            value in supported_parameters for value in ("tools", "tool_choice")
        ):
            tools = "yes"
        else:
            tools = "unknown"
        reasoning = self.draft.reasoning or "model default"

        text = Text(no_wrap=True, overflow="ellipsis")
        text.append(name, style="bold #ffff00")
        text.append(" · ")
        text.append(PROVIDER_LABELS.get(provider, provider), style="#5fd7ff")
        compatibility, compatibility_description = (
            self.openrouter_codex_compatibility(model)
            if provider == "openrouter"
            else ("", "")
        )
        if compatibility:
            _marker, compatibility_style = OPENROUTER_CODEX_STATUS_MARKERS.get(
                compatibility, ("!", "#ffff00")
            )
            text.append(" · Codex: ")
            text.append(compatibility_description, style=compatibility_style)
        text.append("\nID: ")
        text.append(model)
        if provider == "openai" and self.draft.account:
            text.append(f" · Account: {self.draft.account}")
        text.append(
            f"\nContext: {self.token_display(context)} · "
            f"Output: {self.token_display(output)} · Reasoning: {reasoning}"
        )
        state = "UNAVAILABLE" if self.unavailable_draft else f"Auth: {self.auth_summary(provider)}"
        text.append(
            f"\n{state} · Input: {','.join(modalities)} · Tools: {tools}"
        )
        detail.update(text)

    def set_status(
        self, message: str, error: bool = False, hold: bool = False
    ) -> None:
        status = self.query_one("#status", Static)
        self.status_hint_held = error or hold
        text = Text(no_wrap=True, overflow="ellipsis")
        if error:
            text.append("ERROR · ")
        badge_style = {
            "ONLINE": "bold #ffffff on #008700",
            "OFFLINE": "bold #ffffff on #af0000",
        }.get(self.vault_label, "bold #ffffff")
        text.append(f"VAULT {self.vault_label}", style=badge_style)
        text.append(f" · {message}")
        status.update(text)
        status.styles.background = (
            "#870000" if error or self.vault_label == "OFFLINE" else "#000000"
        )

    def render_proxy_statuses(self) -> None:
        text = Text(no_wrap=True, overflow="ellipsis")
        text.append("PROVIDER PROXY ", style="bold #5fd7ff")
        state = self.proxy_states.get("unified")
        value = "ON" if state is True else "OFF" if state is False else "…"
        style = (
            "bold #ffffff on #008700"
            if state is True
            else "bold #ffffff on #af0000"
            if state is False
            else "bold #000000 on #bcbcbc"
        )
        text.append(f" {value} ", style=style)
        text.append(" · OpenCode Go / OpenRouter / Azure", style="#bcbcbc")
        self.query_one("#proxy-status", Static).update(text)

    def proxy_statuses_sync(self) -> dict[str, bool]:
        statuses = self.safe_call("proxy_statuses", {})
        return {"unified": bool(statuses.get("unified"))}

    async def refresh_proxy_statuses(self) -> None:
        self.proxy_states = await asyncio.to_thread(self.proxy_statuses_sync)
        self.render_proxy_statuses()

    def update_status_hint_if_clear(self) -> None:
        """Keep an operation result visible across its programmatic focus change."""
        if not self.status_hint_held:
            self.update_status_hint()

    def update_status_hint(self) -> None:
        try:
            focused = self.focused
        except Exception:
            return
        focused_id = focused.id if focused is not None else ""
        self.last_focus_id = focused_id
        if focused_id == "sources":
            source = self.query_one("#sources", OptionList).highlighted_option
            action = (
                "Enter: add account"
                if source is not None and source.id == "action:add-openai-account"
                else "Enter: models"
            )
        elif focused_id == "model-filter" and self.search_has_no_results:
            action = "No matches · Esc: clear search"
        elif focused_id == "model-filter":
            action = "Enter: select model · Esc: clear search"
        elif focused_id == "models":
            action = "Enter: reasoning"
        elif focused_id == "reasoning":
            action = "Enter: start (sandbox bypass)"
        else:
            action = "←→/Tab: panels · /: search"
        state = "OUT OF SYNC" if self.runtime_drift else (
            "PENDING" if self.selection_is_dirty() else "ACTIVE"
        )
        self.set_status(f"{action} · {state} · {self.status_selection_label()}")

    # ---------- Events and navigation ----------

    def on_click(self, event: Click) -> None:
        if isinstance(event.control, OptionList):
            self.status_hint_held = False
        if isinstance(event.control, FKey) and event.control.fkey_action:
            asyncio.create_task(self.run_action(event.control.fkey_action))
        elif getattr(event.control, "id", None) == "model-sort-model":
            self.action_sort_models_by_model()
        elif getattr(event.control, "id", None) == "model-sort-cost":
            self.action_sort_models_by_cost()

    def on_descendant_focus(self, event: DescendantFocus) -> None:
        focused_id = event.widget.id
        if focused_id in {"sources", "models", "reasoning", "model-filter"}:
            if focused_id != self.last_focus_id:
                self.call_after_refresh(self.update_status_hint_if_clear)

    def on_key(self, event: Key) -> None:
        if event.key in {
            "up",
            "down",
            "home",
            "end",
            "pageup",
            "pagedown",
            "tab",
            "shift+tab",
        }:
            self.status_hint_held = False
        focused = self.focused
        if focused is not None and focused.id == "model-filter":
            models = self.query_one("#models", OptionList)
            if event.key == "up":
                models.action_cursor_up()
                event.prevent_default()
                event.stop()
            elif event.key == "down":
                models.action_cursor_down()
                event.prevent_default()
                event.stop()
            elif event.key == "pageup":
                models.action_page_up()
                event.prevent_default()
                event.stop()
            elif event.key == "pagedown":
                models.action_page_down()
                event.prevent_default()
                event.stop()
            elif event.key == "home":
                models.action_first()
                event.prevent_default()
                event.stop()
            elif event.key == "end":
                models.action_last()
                event.prevent_default()
                event.stop()

    def on_option_list_option_highlighted(
        self, event: OptionList.OptionHighlighted
    ) -> None:
        if self.too_small:
            return
        if not event.option.id:
            return
        highlighted = event.option_list.highlighted_option
        if highlighted is None or highlighted.id != event.option.id:
            return
        if event.option_list.id == "sources" and not self.loading_sources:
            kind, value = event.option.id.split(":", 1)
            if kind == "action":
                self.update_status_hint_if_clear()
                return
            provider = "openai" if kind == "account" else value
            account = value if kind == "account" else (
                self.current_openai_account() if provider == "openai" else None
            )
            same_provider = provider == self.draft.provider
            self.draft = Selection(
                provider,
                account,
                self.draft.model if same_provider else None,
                self.draft.reasoning if same_provider else None,
            )
            self.update_source_markers()
            self.load_models()
            self.update_status_hint_if_clear()
        elif event.option_list.id == "models" and not self.loading_models:
            model = event.option.id.split(":", 1)[1]
            self.draft = replace(self.draft, model=model, reasoning=None)
            self.unavailable_draft = (
                model not in self.model_lists.get(self.draft.provider, [])
                and self.draft.provider in self.catalog_ready
                and not (
                    self.active.provider == self.draft.provider
                    and self.active.model == model
                )
            )
            self.update_model_markers()
            self.update_reasoning()
            self.update_details()
            self.update_status_hint_if_clear()
        elif event.option_list.id == "reasoning" and not self.loading_reasoning:
            raw = event.option.id.split(":", 1)[1]
            value = None if raw == DEFAULT_REASONING_VALUE else raw
            self.draft = replace(self.draft, reasoning=value)
            self.update_reasoning_markers()
            self.update_details()
            self.update_status_hint_if_clear()

    def on_option_list_option_selected(
        self, event: OptionList.OptionSelected
    ) -> None:
        if not event.option.id:
            return
        if event.option_list.id == "sources":
            kind, value = event.option.id.split(":", 1)
            if kind == "action" and value == "add-openai-account":
                self.open_auth("openai")
            else:
                self.action_models()
        elif event.option_list.id == "models":
            self.action_reasoning()
        elif event.option_list.id == "reasoning":
            self.action_codex()

    def on_input_changed(self, event: Input.Changed) -> None:
        if event.input.id == "model-filter" and not self.too_small:
            self.model_filter_query = event.value
            self.load_models()
            self.update_status_hint()

    def on_input_submitted(self, event: Input.Submitted) -> None:
        if event.input.id != "model-filter":
            return
        option = self.query_one("#models", OptionList).highlighted_option
        if option is None or not option.id:
            self.set_status("No matching model to select", error=True)
            return
        model = option.id.split(":", 1)[1]
        self.draft = replace(self.draft, model=model, reasoning=None)
        self.unavailable_draft = False
        self.close_model_filter()
        self.action_reasoning()

    def action_accounts(self) -> None:
        if self.too_small:
            return
        self.query_one("#sources", OptionList).focus()
        self.update_status_hint()

    def action_models(self) -> None:
        if self.too_small:
            return
        self.query_one("#models", OptionList).focus()
        self.update_status_hint()

    def action_reasoning(self) -> None:
        if self.too_small:
            return
        self.query_one("#reasoning", OptionList).focus()
        self.update_status_hint()

    def panel_index(self) -> int:
        focused_id = self.focused.id if self.focused is not None else "sources"
        if focused_id == "model-filter":
            focused_id = "models"
        return {"sources": 0, "models": 1, "reasoning": 2}.get(focused_id, 0)

    def focus_panel(self, index: int) -> None:
        target = ("#sources", "#models", "#reasoning")[index]
        self.query_one(target, OptionList).focus()
        self.update_status_hint()

    def action_previous_panel(self) -> None:
        if self.too_small:
            return
        if self.focused is not None and self.focused.id == "model-filter":
            return
        self.focus_panel(max(0, self.panel_index() - 1))

    def action_next_panel(self) -> None:
        if self.too_small:
            return
        if self.focused is not None and self.focused.id == "model-filter":
            return
        self.focus_panel(min(2, self.panel_index() + 1))

    def action_search_models(self) -> None:
        if self.operation_busy or self.too_small:
            return
        field = self.query_one("#model-filter", Input)
        field.styles.display = "block"
        field.focus()
        self.update_status_hint()

    def set_openrouter_sort(self, column: str) -> None:
        if self.draft.provider != "openrouter":
            return
        if self.openrouter_sort_column == column:
            self.openrouter_sort_descending = not self.openrouter_sort_descending
        else:
            self.openrouter_sort_column = column
            self.openrouter_sort_descending = False
        self.load_models(preserve_missing=True)
        self.query_one("#models", OptionList).focus()
        self.update_status_hint()

    def action_sort_models_by_model(self) -> None:
        self.set_openrouter_sort("model")

    def action_sort_models_by_cost(self) -> None:
        self.set_openrouter_sort("cost")

    def close_model_filter(self) -> None:
        field = self.query_one("#model-filter", Input)
        self.model_filter_query = ""
        field.value = ""
        field.styles.display = (
            "block" if self.draft.provider == "openrouter" else "none"
        )
        self.load_models(preserve_missing=True)
        self.query_one("#models", OptionList).focus()
        self.update_status_hint()

    def action_cancel(self) -> None:
        if self.too_small:
            return
        field = self.query_one("#model-filter", Input)
        if field.has_focus or self.model_filter_query:
            self.close_model_filter()
            return
        if self.draft != self.active:
            self.draft = self.active
            self.load_sources(self.source_target_id(self.active))
            self.load_models()
            self.set_status("Pending selection restored to active configuration")
        elif self.runtime_drift:
            self.set_status(
                "Codex runtime differs from CodexSwitch state; "
                "F6 reapplies the active runtime selection",
                error=True,
            )
        else:
            self.set_status("F10/q quits · F1/? opens help")

    # ---------- Responsive layout ----------

    def on_resize(self, event: Resize) -> None:
        self.update_responsive_ui(event.size.width, event.size.height)

    def update_responsive_ui(self, width: int, height: int) -> None:
        compact_footer = width < 120
        compact_source_title = width < 100
        try:
            self.query_one("#source-title", Label).update(
                "┤ PROVIDERS ├"
                if compact_source_title
                else "┤ PROVIDERS / ACCOUNTS ├"
            )
            for key in self.query(FKey):
                key.set_compact(compact_footer)
            warning = self.query_one("#size-warning", Static)
            too_small = width < 80 or height < 24
            if too_small:
                if self.focused is not None and self.focused.id != "size-warning":
                    self.small_screen_focus = self.focused.id
                warning.update(
                    "Minimum terminal size: 80×24\n"
                    f"Current size: {width}×{height}\n\n"
                    "Resize or press F10/q to quit"
                )
                warning.styles.display = "block"
                if not self.too_small:
                    self.workflow_disabled(True)
                self.too_small = True
            else:
                was_visible = warning.styles.display != "none"
                warning.styles.display = "none"
                self.too_small = False
                if was_visible and not self.operation_busy:
                    self.workflow_disabled(False)
                if was_visible and self.small_screen_focus:
                    try:
                        self.query_one(f"#{self.small_screen_focus}").focus()
                    except Exception:
                        self.query_one("#sources", OptionList).focus()
                    self.small_screen_focus = None
        except Exception:
            return

    # ---------- Help, quit and modal focus ----------

    def remember_modal_focus(self) -> None:
        self.modal_origin = self.focused.id if self.focused is not None else "sources"

    def restore_modal_focus(self, update_status: bool = True) -> None:
        if self.modal_origin:
            try:
                self.query_one(f"#{self.modal_origin}").focus()
            except Exception:
                self.query_one("#sources", OptionList).focus()
        self.modal_origin = None
        if update_status:
            self.update_status_hint()

    def action_help(self) -> None:
        self.remember_modal_focus()
        self.push_screen(HelpScreen(), lambda _: self.restore_modal_focus())

    def action_request_quit(self) -> None:
        if isinstance(self.screen, ModalScreen):
            return
        if self.operation_busy:
            self.set_status("An operation is still running", error=True)
            return
        if not self.selection_is_dirty():
            self.exit()
            return
        self.remember_modal_focus()
        self.push_screen(ConfirmQuitScreen(), self.finish_quit_request)

    def finish_quit_request(self, confirmed: bool | None) -> None:
        if confirmed:
            self.exit()
        else:
            self.restore_modal_focus()

    # ---------- Catalog workers ----------

    def capture(self, function, *args) -> tuple[Any, str]:
        output = io.StringIO()
        with contextlib.redirect_stdout(output), contextlib.redirect_stderr(output):
            try:
                result = function(*args)
            except SystemExit as exc:
                return exc, output.getvalue().strip()
        return result, output.getvalue().strip()

    def provider_data_sync(self, provider: str, refresh: bool) -> dict[str, Any]:
        refreshers = {
            "openai": "refresh_openai_models",
            "opencode-go": "refresh_opencode_models",
            "openrouter": "refresh_openrouter_models",
        }
        getters = {
            "openai": ("openai_models", "openai_model_catalog"),
            "azure": ("azure_models", None),
            "opencode-go": ("opencode_models", "opencode_model_catalog"),
            "openrouter": ("openrouter_models", "openrouter_model_catalog"),
        }
        success = True
        output = ""
        refresher_name = refreshers.get(provider)
        if refresh and refresher_name and self.backend.get(refresher_name):
            result, output = self.capture(self.backend[refresher_name], False)
            success = not isinstance(result, SystemExit) and result is not False
        model_name, catalog_name = getters[provider]
        models = self.safe_call(model_name, self.model_lists.get(provider, []))
        catalog = self.safe_call(catalog_name, {}) if catalog_name else {}
        return {
            "provider": provider,
            "success": success,
            "output": output,
            "models": list(models) if isinstance(models, (list, tuple)) else [],
            "catalog": catalog if isinstance(catalog, dict) else {},
        }

    def apply_provider_data(self, data: dict[str, Any], preserve_missing: bool) -> None:
        provider = data["provider"]
        models = data.get("models") or self.model_lists.get(provider, [])
        if models:
            self.model_lists[provider] = list(dict.fromkeys(models))
        catalog = data.get("catalog")
        if catalog:
            self.catalogs[provider] = catalog
        self.catalog_ready.add(provider)
        if self.draft.provider == provider:
            self.load_models(preserve_missing=preserve_missing)

    def start_startup_refresh(self) -> None:
        if self.operation_busy or self.busy_providers:
            return
        self.run_worker(
            self.startup_refresh_worker(),
            name="startup-catalogs",
            group="catalogs",
            exclusive=True,
            exit_on_error=False,
        )

    async def startup_refresh_worker(self) -> None:
        providers = ("openai", "opencode-go", "openrouter")
        proxy_task = asyncio.create_task(
            asyncio.to_thread(self.proxy_statuses_sync)
        )
        self.busy_providers.update(providers)
        self.vault_label = "CHECKING"
        self.set_status("Checking shared vault…")
        failed = False
        try:
            status_function = self.backend.get("vault_status")
            if status_function:
                try:
                    status = await asyncio.to_thread(status_function)
                except Exception:
                    status = {"mode": "remote", "online": False, "label": "OFFLINE"}
                label = str(status.get("label") or "OFFLINE").upper()
                self.vault_label = label if label in {"LOCAL", "ONLINE", "OFFLINE"} else "OFFLINE"
                failed = failed or not bool(status.get("online"))
            self.set_status("Loading cached model catalogs…")
            for provider in providers:
                try:
                    async with self.backend_worker_lock:
                        data = await asyncio.to_thread(
                            self.provider_data_sync, provider, False
                        )
                    failed = failed or not data["success"]
                    self.apply_provider_data(data, preserve_missing=True)
                except Exception:
                    failed = True
                finally:
                    self.busy_providers.discard(provider)
        finally:
            self.busy_providers.difference_update(providers)
            try:
                self.proxy_states = await proxy_task
            except Exception:
                self.proxy_states = {"unified": False}
            self.render_proxy_statuses()
        if failed:
            self.set_status(
                "Shared vault or a cached catalog is unavailable",
                error=True,
            )
        else:
            self.update_status_hint()

    def action_refresh(self) -> None:
        if self.too_small:
            return
        provider = self.draft.provider
        if self.operation_busy or self.busy_providers:
            self.set_status("A catalog or configuration operation is already running", error=True)
            return
        self.run_worker(
            self.refresh_provider_worker(provider),
            name=f"refresh-{provider}",
            group="catalogs",
            exclusive=True,
            exit_on_error=False,
        )

    async def refresh_provider_worker(self, provider: str) -> None:
        self.busy_providers.add(provider)
        self.set_status(f"Refreshing shared vault and {PROVIDER_LABELS[provider]} catalog…")
        try:
            async with self.backend_worker_lock:
                vault_refresh = self.backend.get("refresh_vault_session_cache")
                if vault_refresh:
                    await asyncio.to_thread(
                        vault_refresh,
                        Path(
                            self.backend.get(
                                "SWITCH_HOME",
                                Path.home() / ".config/codexswitch",
                            )
                        ),
                    )
                data = await asyncio.to_thread(
                    self.provider_data_sync, provider, True
                )
            if not data["success"]:
                self.set_status(
                    "Catalog refresh failed; the existing catalog was retained",
                    error=True,
                )
                return
            self.apply_provider_data(data, preserve_missing=True)
            self.set_status(f"{PROVIDER_LABELS[provider]} catalog refreshed")
        except Exception as exc:
            self.set_status(str(exc) or "Catalog refresh failed", error=True)
        finally:
            self.busy_providers.discard(provider)
            await self.refresh_proxy_statuses()

    # ---------- Apply and launch workers ----------

    def workflow_disabled(self, disabled: bool) -> None:
        for selector in ("#sources", "#models", "#reasoning", "#model-filter"):
            self.query_one(selector).disabled = disabled

    def validate_draft(self) -> bool:
        if self.model_filter_query:
            option = self.query_one("#models", OptionList).highlighted_option
            if self.search_has_no_results or option is None or not option.id:
                self.set_status("No matching model to apply or start", error=True)
                self.query_one("#model-filter", Input).focus()
                return False
            model = option.id.split(":", 1)[1]
            self.draft = replace(self.draft, model=model, reasoning=None)
            self.unavailable_draft = False
            self.close_model_filter()
        if not self.draft.model:
            self.set_status("Select a model first", error=True)
            self.action_models()
            return False
        if self.unavailable_draft:
            self.set_status(
                "The pending model is no longer available; select another model",
                error=True,
            )
            self.action_models()
            return False
        if self.draft.provider in self.busy_providers:
            self.set_status("Wait for the provider refresh to finish", error=True)
            return False
        return True

    def apply_selection_sync(
        self,
        selection: Selection,
        original: Selection,
        original_account: str | None,
    ) -> tuple[bool, str, str]:
        messages: list[str] = []
        needs_account_switch = (
            selection.provider == "openai"
            and selection.account is not None
            and selection.account != original_account
        )

        def rollback_config() -> str:
            if not original.model:
                return "original model is unknown"
            try:
                result, output = self.capture(
                    self.backend["update_codex_config"],
                    original.provider,
                    original.model,
                    original.reasoning,
                )
            except Exception as exc:
                return str(exc) or "configuration rollback failed"
            if isinstance(result, SystemExit):
                return output or "configuration rollback failed"
            return ""

        try:
            result, output = self.capture(
                self.backend["validate_provider_model"],
                selection.provider,
                selection.model,
            )
            if isinstance(result, SystemExit):
                return False, output or "Invalid provider or model", "models"
            result, output = self.capture(
                self.backend["update_codex_config"],
                selection.provider,
                selection.model,
                selection.reasoning,
            )
            if isinstance(result, SystemExit):
                return False, output or "Could not activate selection", "reasoning"
            if output:
                messages.append(output)
            if needs_account_switch:
                try:
                    result, output = self.capture(
                        self.backend["use_openai_account"], selection.account
                    )
                except Exception as exc:
                    rollback_error = rollback_config()
                    message = str(exc) or "Could not activate account"
                    if rollback_error:
                        message += f"; {rollback_error}"
                    return False, message, "sources"
                if isinstance(result, SystemExit):
                    rollback_error = rollback_config()
                    message = output or "Could not activate account"
                    if rollback_error:
                        message += f"; {rollback_error}"
                    return False, message, "sources"
                if output:
                    messages.append(output)
            return True, messages[-1] if messages else "Selection applied", ""
        except Exception as exc:
            return False, str(exc) or "Could not activate selection", "models"

    def request_apply(self, launch: bool) -> None:
        if self.too_small:
            return
        if self.operation_busy:
            self.set_status("A configuration operation is already running", error=True)
            return
        if not self.validate_draft():
            return
        if launch and not self.selection_is_dirty():
            self.launch_codex = True
            self.exit()
            return
        snapshot = self.draft
        original = self.active
        original_account = self.current_openai_account()
        origin = self.focused.id if self.focused is not None else "sources"
        self.run_worker(
            self.apply_worker(
                snapshot, original, launch, origin, original_account
            ),
            name="apply-selection",
            group="configuration",
            exclusive=True,
            exit_on_error=False,
        )

    async def apply_worker(
        self,
        selection: Selection,
        original: Selection,
        launch: bool,
        origin: str,
        original_account: str | None,
    ) -> None:
        self.operation_busy = True
        self.workflow_disabled(True)
        self.set_status("Applying selection…")
        error_message: str | None = None
        error_focus = origin
        try:
            async with self.backend_worker_lock:
                success, message, error_focus = await asyncio.to_thread(
                    self.apply_selection_sync,
                    selection,
                    original,
                    original_account,
                )
            if not success:
                error_message = message
                return
            self.active = self.read_active_selection()
            self.draft = self.active
            self.load_sources(self.source_target_id(self.active))
            self.load_models(preserve_missing=True)
            if self.runtime_drift:
                error_message = (
                    "Selection was written, but Codex runtime and "
                    "CodexSwitch state are still out of sync"
                )
                return
            if launch:
                self.launch_codex = True
                self.exit()
                return
            self.set_status(
                f"Active · {self.status_selection_label(self.active)}", hold=True
            )
        finally:
            self.operation_busy = False
            if not self.launch_codex:
                if not self.too_small:
                    self.workflow_disabled(False)
                try:
                    self.query_one(f"#{error_focus if error_message else origin}").focus()
                except Exception:
                    self.query_one("#sources", OptionList).focus()
                if error_message:
                    self.set_status(error_message, error=True)

    def action_apply(self) -> None:
        self.request_apply(launch=False)

    def action_codex(self) -> None:
        self.request_apply(launch=True)

    def action_status(self) -> None:
        if self.too_small:
            return
        if self.operation_busy:
            self.set_status("A configuration operation is still running", error=True)
            return
        self.active = self.read_active_selection()
        self.draft = self.active
        field = self.query_one("#model-filter", Input)
        self.model_filter_query = ""
        self.search_has_no_results = False
        field.value = ""
        field.styles.display = "none"
        self.load_sources(self.source_target_id(self.active))
        self.load_models()
        if self.runtime_drift:
            self.set_status(
                "Out of sync · Codex runtime and CodexSwitch state differ; "
                "F6 reapplies this selection",
                error=True,
            )
        else:
            self.set_status(
                f"Active status reloaded · {self.status_selection_label(self.active)}",
                hold=True,
            )

    # ---------- Authentication ----------

    def action_auth(self) -> None:
        self.open_auth(self.draft.provider)

    def open_auth(self, provider: str) -> None:
        if self.too_small:
            return
        if self.operation_busy or self.busy_providers:
            self.set_status("A configuration operation is already running", error=True)
            return
        self.remember_modal_focus()
        if provider == "openai":
            self.push_screen(
                OpenAIAuthScreen(),
                lambda result: self.finish_openai_auth(result),
            )
            return
        if provider == "azure":
            credential = self.safe_call("azure_credentials", {})
            if not isinstance(credential, dict):
                credential = {}
            endpoint = credential.get("endpoint") or self.backend.get(
                "AZURE_DEFAULT_ENDPOINT", ""
            )
            self.push_screen(
                AzureAuthScreen(str(endpoint)),
                lambda payload: self.finish_credential_modal(provider, payload),
            )
            return
        self.push_screen(
            ApiKeyScreen(provider),
            lambda payload: self.finish_credential_modal(provider, payload),
        )

    def finish_openai_auth(self, result: str | None) -> None:
        if result != "start":
            self.restore_modal_focus()
            return
        self.run_openai_device_auth()

    def run_openai_device_auth(self) -> None:
        self.set_status("Starting OpenAI device sign-in…")
        try:
            with self.suspend():
                subprocess.run(
                    [str(BACKEND_PATH), "auth", "openai"],
                    check=True,
                    env={**os.environ, "HOME": str(self.backend.get("HOME", Path.home()))},
                )
            auth_path = Path(self.backend["CODEX_HOME"]) / "auth.json"
            auth = self.read_backend_json(auth_path, {})
            email = self.safe_call("openai_auth_email", None, auth)
            if not email:
                self.set_status(
                    "OpenAI login completed, but no account email was detected",
                    error=True,
                )
                return
            same_provider = self.draft.provider == "openai"
            self.draft = Selection(
                "openai",
                email,
                self.draft.model if same_provider else None,
                self.draft.reasoning if same_provider else None,
            )
            self.load_sources(f"account:{email}")
            self.load_models()
            self.set_status(f"OpenAI account added · {email}", hold=True)
        except subprocess.CalledProcessError:
            self.set_status("OpenAI sign-in was not completed", error=True)
        except Exception as exc:
            self.set_status(str(exc) or "OpenAI sign-in failed", error=True)
        finally:
            self.restore_modal_focus(update_status=False)

    def finish_credential_modal(self, provider: str, payload: Any) -> None:
        if not payload:
            self.restore_modal_focus()
            return
        origin = self.modal_origin or "sources"
        self.modal_origin = None
        self.run_worker(
            self.save_credentials_worker(provider, payload, origin),
            name=f"auth-{provider}",
            group="configuration",
            exclusive=True,
            exit_on_error=False,
        )

    def save_credentials_sync(
        self, provider: str, payload: Any
    ) -> tuple[bool, str, dict[str, Any], bool]:
        saved = False
        try:
            if provider == "azure":
                endpoint, key = payload
                result, output = self.capture(
                    self.backend["save_azure_credentials"], endpoint, key
                )
            elif provider == "opencode-go":
                result, output = self.capture(
                    self.backend["save_opencode_go_key"], payload
                )
            else:
                result, output = self.capture(
                    self.backend["save_openrouter_key"], payload
                )
            if isinstance(result, SystemExit):
                return False, output or "Credentials were not saved", {}, False
            saved = True
            data = self.provider_data_sync(provider, provider != "azure")
            return True, output or "Credentials saved", data, bool(data["success"])
        except Exception as exc:
            if saved:
                return True, str(exc) or "Catalog refresh failed", {}, False
            return False, str(exc) or "Credentials were not saved", {}, False

    async def save_credentials_worker(
        self, provider: str, payload: Any, origin: str
    ) -> None:
        self.operation_busy = True
        self.busy_providers.add(provider)
        self.set_status(f"Saving {PROVIDER_LABELS[provider]} credentials…")
        final_message = ""
        final_error = False
        try:
            async with self.backend_worker_lock:
                success, message, data, refresh_ok = await asyncio.to_thread(
                    self.save_credentials_sync, provider, payload
                )
            if not success:
                final_message = message
                final_error = True
                return
            if data and refresh_ok:
                self.apply_provider_data(data, preserve_missing=True)
            if refresh_ok:
                final_message = f"{PROVIDER_LABELS[provider]} credentials saved"
            else:
                final_message = (
                    f"{PROVIDER_LABELS[provider]} credentials saved; "
                    "catalog refresh failed and the existing catalog was retained"
                )
                final_error = True
        finally:
            self.operation_busy = False
            self.busy_providers.discard(provider)
            try:
                self.query_one(f"#{origin}").focus()
            except Exception:
                self.query_one("#sources", OptionList).focus()
            if final_message:
                self.set_status(final_message, error=final_error, hold=True)


def codex_launch_argv(binary: str | None = None) -> list[str]:
    binary = binary or BACKEND.get("codex_launch_bin", BACKEND["codex_bin"])()
    if os.name == "nt":
        shim = Path(binary)
        if shim.suffix.lower() in {".cmd", ".bat"}:
            package_root = shim.parent / "node_modules" / "@openai" / "codex"
            candidates = sorted(
                package_root.glob(
                    "node_modules/@openai/codex-win32-*/vendor/*/bin/codex.exe"
                )
            )
            if candidates:
                binary = str(candidates[0])
    return [binary, *CODEX_TUI_LAUNCH_ARGS]


def main() -> int:
    app = CodexSwitchApp()
    app.run()
    if app.launch_codex:
        BACKEND["ensure_provider_proxy"](app.active.provider)
        BACKEND["ensure_codex_runtime_writable"]()
        argv = codex_launch_argv()
        environment = BACKEND["codex_launch_environment"]()
        if os.name == "nt":
            return subprocess.run(
                argv,
                env=environment,
            ).returncode
        os.execvpe(argv[0], argv, environment)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
