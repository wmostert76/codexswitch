#!/usr/bin/env python3
"""Launch the shared compatibility proxy in OpenRouter mode."""

import os
import sys
from pathlib import Path


proxy = Path(__file__).resolve().with_name("codex-opencode-go-proxy")
environment = dict(os.environ)
environment["CODEXSWITCH_PROXY_PROVIDER"] = "openrouter"
environment.setdefault("CODEXSWITCH_PROXY_PORT", "14556")
os.execve(sys.executable, [sys.executable, str(proxy)], environment)
