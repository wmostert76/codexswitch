#!/usr/bin/env python3
import asyncio
import contextlib
import io
import os
import runpy
import subprocess
from pathlib import Path

from rich.text import Text
from textual.app import App, ComposeResult
from textual.binding import Binding
from textual.containers import Horizontal, Vertical
from textual.screen import ModalScreen
from textual.widgets import Button, Header, Label, OptionList, Static
from textual.widgets.option_list import Option

from textual.events import Click


PROJECT = Path(__file__).resolve().parents[1]
BACKEND_PATH = PROJECT / "bin/codexswitch"
BACKEND = runpy.run_path(str(BACKEND_PATH))

FKEY_ACTIONS = {
    "1": "help",
    "2": "accounts",
    "3": "models",
    "4": "reasoning",
    "5": "refresh",
    "6": "apply",
    "7": "auth",
    "8": "status",
    "9": "codex",
    "10": "quit",
}
CODEX_TUI_LAUNCH_ARGS = (
    "resume",
    "--dangerously-bypass-approvals-and-sandbox",
    "--search",
)
FUNCTION_KEYS = (
    ("1", "Help"),
    ("2", "Prov"),
    ("3", "Model"),
    ("4", "Think"),
    ("5", "Fresh"),
    ("6", "Apply"),
    ("7", "Auth"),
    ("8", "Stat"),
    ("9", "Codex"),
    ("10", "Quit"),
)



class FKey(Static):
    """A clickable function-key label styled like Midnight Commander."""

    def __init__(self, *args, action: str = "", **kwargs) -> None:
        super().__init__(*args, **kwargs)
        self.fkey_action = action


def splash_line(text: str) -> str:
    return text.center(BACKEND["ASCII_LOGO_WIDTH"])


class SplashScreen(ModalScreen):
    BINDINGS = [
        ("enter", "dismiss", "Continue"),
        ("escape", "dismiss", "Continue"),
        ("space", "dismiss", "Continue"),
    ]

    def compose(self) -> ComposeResult:
        yield Static(
            f"""[bold cyan]{BACKEND['BRAND_BANNER']}[/]

[bold yellow]{splash_line(f"CodexSwitch Commander v{BACKEND['VERSION']}")}[/]
[bold white]{splash_line(BACKEND['CREDITS_OWNER'])}[/]
[green]{splash_line(BACKEND['CREDITS_AI'])}[/]

[dim]{splash_line("Enter / Space / Esc / Click to continue")}[/]
""",
            id="splash-dialog",
            markup=True,
        )

    def on_click(self, event: Click) -> None:
        self.dismiss()


class HelpScreen(ModalScreen):
    BINDINGS = [("escape", "dismiss", "Close"), ("f1", "dismiss", "Close")]

    def compose(self) -> ComposeResult:
        yield Static(
            """
[bold #000087]CODEXSWITCH COMMANDER HELP[/]

[b]NAVIGATION[/]
  Tab · Shift+Tab   Switch panel
  ↑ ↓               Move selection
  Enter             Open or activate

[b]FUNCTION KEYS[/]
  F1  Help          This screen
  F2  Providers     Focus provider/account panel
  F3  Models        Focus model panel
  F4  Reasoning     Focus reasoning modes
  F5  Refresh       Refresh OpenCode Go catalog
  F6  Apply         Activate selection
  F7  Auth          Login to selected provider
  F8  Status        Reload active configuration
  F9  Codex         Resume Codex with bypass sandbox and search
  F10 Quit          Close CodexSwitch

[dim]Press Escape, F1 or click to close.[/]
""",
            id="help-dialog",
            markup=True,
        )

    def on_click(self, event: Click) -> None:
        self.dismiss()


class OpenAIAuthScreen(ModalScreen):
    BINDINGS = [
        ("enter", "start", "Start"),
        ("escape", "dismiss", "Cancel"),
    ]

    def compose(self) -> ComposeResult:
        yield Static(
            """
[bold #000087]OPENAI DEVICE SIGN-IN[/]

CodexSwitch will temporarily leave the TUI and start:

  codex login --device-auth

Codex will show a URL and device code. Open the URL, enter the code,
finish login in your browser, then return here. When Codex reports the
login is complete, CodexSwitch verifies ~/.codex/auth.json, saves the
account and refreshes the provider/account list.

[b]Enter[/] Start sign-in    [b]Esc[/] Cancel
""",
            id="openai-auth-dialog",
            markup=True,
        )
        yield Button("Start OpenAI sign-in", id="start-openai-auth")

    def action_start(self) -> None:
        self.dismiss()
        self.app.run_openai_device_auth()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "start-openai-auth":
            self.action_start()


class CodexSwitchApp(App):
    TITLE = "CodexSwitch Commander"
    SUB_TITLE = f"v{BACKEND['VERSION']} · {BACKEND['CREDITS_OWNER']}"

    CSS = """
    Screen {
        background: #000087;
        color: #bcbcbc;
    }

    Header {
        height: 1;
        background: #00afaf;
        color: #000000;
        text-style: bold;
    }

    #workspace {
        height: 1fr;
        padding: 0 1;
    }

    .pane {
        height: 1fr;
        border: solid #bcbcbc;
        background: #000087;
    }

    .pane:focus-within, #reason-box:focus-within {
        border: heavy #ffff00;
    }

    #model-pane {
        width: 1fr;
    }

    #source-pane {
        width: 38;
    }

    .pane-title {
        height: 1;
        background: #bcbcbc;
        color: #000087;
        text-align: center;
        text-style: bold;
    }

    .pane:focus-within > .pane-title,
    #reason-box:focus-within > .lower-title {
        background: #ffff00;
        color: #000000;
    }

    OptionList {
        height: 1fr;
        background: #000087;
        color: #bcbcbc;
        padding: 0;
        border: none;
        scrollbar-color: #00afaf;
        scrollbar-background: #000087;
    }

    OptionList > .option-list--option-highlighted {
        background: #00afaf;
        color: #000000;
        text-style: bold;
    }

    #lower-pane {
        height: 9;
        margin: 0 1;
    }

    #detail-box, #reason-box {
        height: 1fr;
        border: solid #bcbcbc;
        background: #000087;
    }

    #detail-box {
        width: 2fr;
        padding: 0 1;
    }

    #reason-box {
        width: 30;
    }

    .lower-title {
        height: 1;
        background: #bcbcbc;
        color: #000087;
        text-align: center;
        text-style: bold;
    }

    #model-detail {
        height: 1fr;
        color: #bcbcbc;
    }

    #reasoning {
        width: 1fr;
        height: 1fr;
    }

    #status {
        height: 1;
        margin: 0 1;
        background: #000000;
        color: #ffffff;
        padding: 0 1;
    }

    #buttonbar {
        height: 1;
        background: #00afaf;
        color: #000000;
        text-align: center;
        text-style: bold;
    }

    FKey {
        width: 1fr;
        height: 1;
        background: #00afaf;
        color: #000000;
        text-align: left;
        text-style: bold;
    }

    FKey:hover {
        background: #ffffff;
        color: #000087;
    }

    FKey:focus {
        background: #ffff00;
        color: #000000;
    }

    .fkey {
        width: 1fr;
        height: 1;
        background: #00afaf;
        color: #000000;
        text-align: left;
        text-style: bold;
    }

    SplashScreen {
        align: center middle;
        background: rgba(0, 0, 0, 0.65);
    }

    HelpScreen {
        align: center middle;
        background: rgba(0, 0, 0, 0.65);
    }

    OpenAIAuthScreen {
        align: center middle;
        background: rgba(0, 0, 0, 0.65);
    }

    #splash-dialog {
        width: 64;
        height: 14;
        border: double #ffff00;
        background: #00005f;
        color: #ffffff;
        padding: 1 2;
        text-style: bold;
    }

    #help-dialog {
        width: 66;
        height: 25;
        border: double #ffffff;
        background: #bcbcbc;
        color: #000000;
        padding: 1 2;
    }

    #openai-auth-dialog {
        width: 72;
        height: 19;
        border: double #ffffff;
        background: #bcbcbc;
        color: #000000;
        padding: 1 2;
    }

    #start-openai-auth {
        width: 28;
        margin-top: 1;
    }
    """

    BINDINGS = [
        Binding("f1", "help", "Help", show=False),
        Binding("f2", "accounts", "Accounts", show=False),
        Binding("f3", "models", "Models", show=False),
        Binding("f4", "reasoning", "Reason", show=False),
        Binding("f5", "refresh", "Refresh", show=False),
        Binding("f6", "apply", "Apply", show=False),
        Binding("f7", "auth", "Auth", show=False),
        Binding("f8", "status", "Status", show=False),
        Binding("f9", "codex", "Codex", show=False),
        Binding("f10", "quit", "Quit", show=False),
        Binding("escape", "quit", "Quit", show=False),
    ]

    def __init__(self):
        super().__init__()
        self.provider = "openai"
        self.account = None
        self.model = None
        self.catalog = {}
        self.openai_metadata = {}
        self.launch_codex = False
        self.loading_sources = False

    def compose(self) -> ComposeResult:
        yield Header(show_clock=True)
        with Horizontal(id="workspace"):
            with Vertical(classes="pane", id="model-pane"):
                yield Label("┤ MODELS ├", classes="pane-title")
                yield OptionList(id="models")
            with Vertical(classes="pane", id="source-pane"):
                yield Label("┤ PROVIDERS / ACCOUNTS ├", classes="pane-title")
                yield OptionList(id="sources")
        with Horizontal(id="lower-pane"):
            with Vertical(id="detail-box"):
                yield Label("┤ MODEL DETAILS ├", classes="lower-title")
                yield Static("", id="model-detail")
            with Vertical(id="reason-box"):
                yield Label("┤ REASONING ├", classes="lower-title")
                yield OptionList(id="reasoning")
        yield Static(" Ready", id="status")
        with Horizontal(id="buttonbar"):
            for number, label in FUNCTION_KEYS:
                yield FKey(
                    f"[reverse bold]{number:>2}[/] {label}",
                    classes="fkey",
                    id=f"fkey-{FKEY_ACTIONS[number]}",
                    action=FKEY_ACTIONS[number],
                    markup=True,
                )

    def on_mount(self) -> None:
        self.load_state()
        self.load_sources()
        self.load_models()
        self.query_one("#models", OptionList).focus()
        self.push_screen(SplashScreen())

    def on_click(self, event: Click) -> None:
        """Handle mouse clicks on function key labels."""
        if isinstance(event.control, FKey) and event.control.fkey_action:
            asyncio.ensure_future(self.run_action(event.control.fkey_action))

    def capture(self, function, *args):
        output = io.StringIO()
        with contextlib.redirect_stdout(output), contextlib.redirect_stderr(output):
            try:
                result = function(*args)
            except SystemExit as exc:
                return exc, output.getvalue().strip()
        return result, output.getvalue().strip()

    def set_status(self, message: str, error: bool = False) -> None:
        status = self.query_one("#status", Static)
        status.update((" ERROR: " if error else " ") + message)
        status.styles.background = "#870000" if error else "#000000"

    def load_state(self) -> None:
        state = BACKEND["read_json"](BACKEND["SWITCH_CONFIG"], {})
        self.provider = state.get("provider", "openai")
        self.model = state.get("model")
        auth = BACKEND["read_json"](BACKEND["CODEX_HOME"] / "auth.json", {})
        if self.provider not in {"openai", "opencode-go", "openrouter"}:
            self.provider = "openai"
        self.account = (
            BACKEND["openai_auth_email"](auth)
            if self.provider == "openai"
            else None
        )
        self.catalog = BACKEND["opencode_model_catalog"]()
        self.openai_metadata = BACKEND["openai_model_catalog"]()

    def source_options(self) -> list[Option]:
        openai_active = self.provider == "openai"
        opencode_active = self.provider == "opencode-go"
        openrouter_active = self.provider == "openrouter"
        options = [
            Option(
                Text.from_markup(
                    f"[b]{'●' if openai_active else '○'} OPENAI[/]"
                ),
                id="provider:openai",
            )
        ]
        accounts = BACKEND["openai_accounts"]()
        for index, email in enumerate(accounts):
            branch = "├─"
            marker = "●" if openai_active and email == self.account else "○"
            options.append(
                Option(f"  {branch} {marker} {email}", id=f"account:{email}")
            )
        options.append(
            Option("  └─ + add OpenAI account", id="action:add-openai-account")
        )
        options.append(
            Option(
                Text.from_markup(
                    f"[b]{'●' if opencode_active else '○'} OPENCODE GO[/]"
                ),
                id="provider:opencode-go",
            )
        )
        options.append(
            Option(
                Text.from_markup(
                    f"[b]{'●' if openrouter_active else '○'} OPENROUTER[/]"
                ),
                id="provider:openrouter",
            )
        )
        return options

    def load_sources(self) -> None:
        sources = self.query_one("#sources", OptionList)
        self.loading_sources = True
        try:
            sources.set_options(self.source_options())
            target = f"account:{self.account}" if self.provider == "openai" and self.account else f"provider:{self.provider}"
            for index, option in enumerate(sources.options):
                if option.id == target:
                    sources.highlighted = index
                    break
        finally:
            self.loading_sources = False

    def update_source_markers(self) -> None:
        sources = self.query_one("#sources", OptionList)
        replacement = self.source_options()
        if len(replacement) != len(sources.options):
            self.load_sources()
            return
        for index, option in enumerate(replacement):
            sources.replace_option_prompt_at_index(index, option.prompt)

    def load_models(self) -> None:
        if self.provider == "openai":
            models = BACKEND["openai_models"]()
        elif self.provider == "opencode-go":
            models = BACKEND["opencode_models"]()
        else:
            models = BACKEND["openrouter_models"]()
        options = []
        for model in models:
            marker = "●" if model == self.model else "○"
            options.append(Option(f" {marker}  {model}", id=f"model:{model}"))
        model_list = self.query_one("#models", OptionList)
        model_list.set_options(options)
        if self.provider == "openai":
            default_model = "gpt-5.5"
        elif self.provider == "opencode-go":
            default_model = BACKEND["DEFAULT_OPENCODE_MODEL"]
        else:
            default_model = BACKEND["OPENROUTER_FALLBACK_MODELS"][0]
        selected_index = 0
        for index, option in enumerate(model_list.options):
            if option.id == f"model:{self.model or default_model}":
                selected_index = index
                break
        if options:
            model_list.highlighted = selected_index
            self.model = model_list.highlighted_option.id.split(":", 1)[1]
        self.update_details()

    def update_details(self) -> None:
        detail = self.query_one("#model-detail", Static)
        reasoning = self.query_one("#reasoning", OptionList)
        if not self.model:
            detail.update("No model available")
            reasoning.set_options([Option("  model default", id="reason:medium")])
            reasoning.highlighted = 0
            return

        if self.provider == "opencode-go":
            meta = self.catalog.get(self.model, {})
            limits = meta.get("limit", {})
            capabilities = meta.get("capabilities", {})
            modalities = [
                name
                for name, enabled in capabilities.get("input", {"text": True}).items()
                if enabled
            ]
            variants = BACKEND["reasoning_choices"](self.model)
            choices = variants or [("model-default", "medium")]
            status = meta.get("status", "active")
            detail.update(
                f"[bold #ffff00]{meta.get('name', self.model)}[/]  "
                f"[#5fd7ff]{meta.get('family', 'unknown')}[/]\n"
                f"Context: {limits.get('context', '?'):,}   Output: {limits.get('output', '?'):,}   "
                f"Status: {status}\n"
                f"Input: {', '.join(modalities) or 'text'}   Tools: "
                f"{'yes' if capabilities.get('toolcall') else 'no'}"
            )
        elif self.provider == "openai":
            meta = self.openai_metadata.get(self.model, {})
            context = meta.get("context_window", "?")
            context_display = f"{context:,}" if isinstance(context, int) else str(context)
            choices = BACKEND["openai_reasoning_choices"](self.model) or [
                ("model-default", "medium")
            ]
            detail.update(
                f"[bold #ffff00]{meta.get('display_name', self.model)}[/]  "
                f"[#5fd7ff]OpenAI[/]\n"
                f"Context: {context_display}   "
                f"Default reasoning: {meta.get('default_reasoning_level', 'medium')}\n"
                f"Account: {self.account or 'not detected'}"
            )
        else:
            meta = BACKEND["openrouter_model_catalog"]().get(self.model, {})
            architecture = meta.get("architecture", {}) if isinstance(meta, dict) else {}
            context = meta.get("context_length", "?") if isinstance(meta, dict) else "?"
            context_display = f"{context:,}" if isinstance(context, int) else str(context)
            input_modalities = architecture.get("input_modalities", ["text"]) if isinstance(architecture, dict) else ["text"]
            choices = [("model-default", "medium")]
            detail.update(
                f"[bold #ffff00]{meta.get('name', self.model) if isinstance(meta, dict) else self.model}[/]  "
                f"[#5fd7ff]OpenRouter[/]\n"
                f"Context: {context_display}   Input: {', '.join(input_modalities)}\n"
                f"Auth: {'ok' if BACKEND['openrouter_key_present']() else 'missing'}"
            )

        state = BACKEND["read_json"](BACKEND["SWITCH_CONFIG"], {})
        current = state.get("reasoning_effort")
        values = {value for _, value in choices}
        if current not in values:
            current = BACKEND["default_reasoning_effort"](self.model) if self.provider == "opencode-go" else meta.get("default_reasoning_level", "medium")
        if current not in values:
            current = choices[0][1]
        reason_options = []
        selected_index = 0
        for index, (label, value) in enumerate(choices):
            marker = "●" if value == current else "○"
            reason_options.append(
                Option(f" {marker}  {label}", id=f"reason:{value}")
            )
            if value == current:
                selected_index = index
        reasoning.set_options(reason_options)
        reasoning.highlighted = selected_index

    def select_source(self, option_id: str) -> None:
        kind, value = option_id.split(":", 1)
        if kind == "action":
            return
        if kind == "account":
            self.provider = "openai"
            self.account = value
        else:
            self.provider = value
            if value == "openai":
                auth = BACKEND["read_json"](BACKEND["CODEX_HOME"] / "auth.json", {})
                self.account = BACKEND["openai_auth_email"](auth)
            else:
                self.account = None
        self.model = None
        self.update_source_markers()
        self.load_models()
        self.set_status(f"Selected {self.provider}")

    def on_option_list_option_highlighted(self, event: OptionList.OptionHighlighted) -> None:
        if event.option_list.id == "sources" and event.option.id and not self.loading_sources:
            kind, value = event.option.id.split(":", 1)
            if kind == "action":
                return
            selected_provider = "openai" if kind == "account" else value
            selected_account = value if kind == "account" else (
                self.account if selected_provider == "openai" else None
            )
            if selected_provider != self.provider or selected_account != self.account:
                self.select_source(event.option.id)
        elif event.option_list.id == "models" and event.option.id:
            self.model = event.option.id.split(":", 1)[1]
            self.update_details()
        elif event.option_list.id == "reasoning" and event.option.id:
            self.mark_reasoning(event.option.id.split(":", 1)[1])

    def on_option_list_option_selected(self, event: OptionList.OptionSelected) -> None:
        if not event.option.id:
            return
        if event.option_list.id == "sources":
            kind, value = event.option.id.split(":", 1)
            if kind == "action" and value == "add-openai-account":
                self.provider = "openai"
                self.account = None
                self.action_auth()
                return
            selected_provider = "openai" if kind == "account" else value
            selected_account = value if kind == "account" else (
                self.account if selected_provider == "openai" else None
            )
            if selected_provider != self.provider or selected_account != self.account:
                self.select_source(event.option.id)
            self.query_one("#models", OptionList).focus()
        elif event.option_list.id == "models":
            self.model = event.option.id.split(":", 1)[1]
            self.update_details()
            self.query_one("#reasoning", OptionList).focus()
        elif event.option_list.id == "reasoning":
            self.action_apply()

    def action_help(self) -> None:
        self.push_screen(HelpScreen())

    def action_accounts(self) -> None:
        self.query_one("#sources", OptionList).focus()

    def action_models(self) -> None:
        self.query_one("#models", OptionList).focus()

    def action_reasoning(self) -> None:
        self.query_one("#reasoning", OptionList).focus()

    def selected_reasoning(self) -> str | None:
        reasoning = self.query_one("#reasoning", OptionList)
        option = reasoning.highlighted_option
        if option is None or not option.id:
            return None
        return option.id.split(":", 1)[1]

    def mark_reasoning(self, selected: str) -> None:
        reasoning = self.query_one("#reasoning", OptionList)
        for index, option in enumerate(reasoning.options):
            if not option.id:
                continue
            value = option.id.split(":", 1)[1]
            label = str(option.prompt).lstrip(" ●○")
            marker = "●" if value == selected else "○"
            reasoning.replace_option_prompt_at_index(
                index, f" {marker}  {label}"
            )

    def action_refresh(self) -> None:
        if self.provider == "openrouter":
            self.set_status("Refreshing OpenRouter catalog...")
            result, output = self.capture(BACKEND["refresh_openrouter_models"])
        else:
            self.set_status("Refreshing OpenCode Go catalog...")
            result, output = self.capture(BACKEND["refresh_opencode_models"])
        if isinstance(result, SystemExit):
            self.set_status(
                output or "Model refresh failed; existing cache retained",
                error=True,
            )
            return
        if self.provider == "opencode-go":
            self.catalog = BACKEND["opencode_model_catalog"]()
        self.load_models()
        self.set_status(output.splitlines()[-1] if output else "Catalog refreshed")

    def action_apply(self) -> None:
        if not self.model:
            self.set_status("Select a model first", error=True)
            return
        try:
            output = []
            if self.provider == "openai" and self.account:
                result, text = self.capture(
                    BACKEND["use_openai_account"], self.account
                )
                if isinstance(result, SystemExit):
                    self.set_status(
                        text or "Could not activate account", error=True
                    )
                    return
                output.append(text)
            result, text = self.capture(
                BACKEND["validate_provider_model"], self.provider, self.model
            )
            if isinstance(result, SystemExit):
                self.set_status(
                    text or "Invalid provider or model", error=True
                )
                return
            effort = self.selected_reasoning()
            result, text = self.capture(
                BACKEND["update_codex_config"], self.provider, self.model, effort
            )
            if isinstance(result, SystemExit):
                self.set_status(
                    text or "Could not activate selection", error=True
                )
                return
            output.append(text)
            self.load_state()
            self.load_sources()
            self.load_models()
            self.set_status(
                f"Active: {self.provider} / {self.model}"
                + (f" / {effort}" if effort else "")
            )
        except Exception as exc:
            self.set_status(str(exc) or "Could not activate selection", error=True)

    def action_auth(self) -> None:
        if self.provider == "openai":
            return self.push_screen(OpenAIAuthScreen())
        self.set_status(f"Starting {self.provider} authentication...")
        try:
            with self.suspend():
                subprocess.run(
                    [str(BACKEND_PATH), "auth", self.provider],
                    check=True,
                    env={**os.environ, "HOME": str(BACKEND["HOME"])},
                )
            self.load_state()
            self.load_sources()
            self.set_status(f"{self.provider} authentication completed")
        except subprocess.CalledProcessError:
            self.set_status("Authentication was not completed", error=True)

    def run_openai_device_auth(self) -> None:
        self.set_status("Starting OpenAI device sign-in...")
        try:
            with self.suspend():
                subprocess.run(
                    [str(BACKEND_PATH), "auth", "openai"],
                    check=True,
                    env={**os.environ, "HOME": str(BACKEND["HOME"])},
                )
            auth = BACKEND["read_json"](BACKEND["CODEX_HOME"] / "auth.json", {})
            email = BACKEND["openai_auth_email"](auth)
            if not email:
                self.set_status(
                    "OpenAI login completed, but no account email was detected",
                    error=True,
                )
                return
            self.account = email
            self.provider = "openai"
            self.load_state()
            self.load_sources()
            self.load_models()
            self.set_status(f"OpenAI account added: {email}")
        except subprocess.CalledProcessError:
            self.set_status("OpenAI sign-in was not completed", error=True)
        except Exception as exc:
            self.set_status(str(exc) or "OpenAI sign-in failed", error=True)

    def action_status(self) -> None:
        self.load_state()
        self.load_sources()
        self.load_models()
        self.set_status(
            f"Active: {self.provider} / {self.model}"
            + (f" / {self.account}" if self.provider == "openai" and self.account else "")
        )

    def selection_is_dirty(self) -> bool:
        """Check if current selection differs from the active config."""
        state = BACKEND["read_json"](BACKEND["SWITCH_CONFIG"], {})
        if self.provider != state.get("provider"):
            return True
        if self.model and self.model != state.get("model"):
            return True
        if self.provider == "openai" and self.account:
            auth = BACKEND["read_json"](BACKEND["CODEX_HOME"] / "auth.json", {})
            active_account = BACKEND["openai_auth_email"](auth)
            if self.account != active_account:
                return True
        effort = self.selected_reasoning()
        if effort and effort != state.get("reasoning_effort"):
            return True
        return False

    def action_codex(self) -> None:
        if self.selection_is_dirty():
            self.set_status("Applying selection...")
            self.action_apply()
            if self.selection_is_dirty():
                self.set_status("Could not apply selection; press F6 to retry", error=True)
                return
        self.launch_codex = True
        self.exit()


def main() -> int:
    app = CodexSwitchApp()
    app.run()
    if app.launch_codex:
        argv = codex_launch_argv()
        os.execvp(argv[0], argv)
    return 0


def codex_launch_argv(binary: str | None = None) -> list[str]:
    binary = binary or BACKEND["codex_bin"]()
    return [binary, *CODEX_TUI_LAUNCH_ARGS]


if __name__ == "__main__":
    raise SystemExit(main())
