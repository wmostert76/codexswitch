#!/usr/bin/env python3
import json
import os
import pwd
import sys
from pathlib import Path


def user_home() -> Path:
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user and sudo_user != "root":
        try:
            return Path(pwd.getpwnam(sudo_user).pw_dir)
        except KeyError:
            pass
    return Path(os.environ.get("HOME", str(Path.home()))).expanduser()


def main() -> int:
    auth_path = user_home() / ".local/share/opencode/auth.json"
    try:
        data = json.loads(auth_path.read_text())
    except FileNotFoundError:
        print(f"OpenCode auth not found: {auth_path}", file=sys.stderr)
        return 1
    except json.JSONDecodeError as exc:
        print(f"OpenCode auth is not valid JSON: {auth_path}: {exc}", file=sys.stderr)
        return 1

    credential = data.get("opencode-go") or {}
    key = credential.get("key")
    if not key:
        print("OpenCode Go API key not found in OpenCode auth store", file=sys.stderr)
        return 1

    print(key)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
