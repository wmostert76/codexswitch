#!/usr/bin/env python3
"""Return one provider credential to the local Go proxy over stdout."""

import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from codexswitch_backend import openrouter_credentials  # noqa: E402
from codexswitch_common import read_secret_json, user_home  # noqa: E402


def main() -> int:
    if len(sys.argv) != 2 or sys.argv[1] not in {"azure", "opencode-go", "openrouter"}:
        print("usage: codexswitch-provider-credential PROVIDER", file=sys.stderr)
        return 2
    provider = sys.argv[1]
    home = user_home()
    if provider == "openrouter":
        value = openrouter_credentials()
    else:
        value = read_secret_json(
            home / f".config/codexswitch/{provider}/auth.json", {}
        )
    if not isinstance(value, dict) or not value:
        print(f"{provider} credential ontbreekt", file=sys.stderr)
        return 1
    sys.stdout.write(json.dumps(value, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
