#!/usr/bin/env python3
import json
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from codexswitch_common import user_home


def main() -> int:
    auth_path = user_home() / ".config/codexswitch/openrouter/auth.json"
    try:
        data = json.loads(auth_path.read_text())
    except FileNotFoundError:
        print(f"OpenRouter auth not found: {auth_path}", file=sys.stderr)
        return 1
    except json.JSONDecodeError as exc:
        print(f"OpenRouter auth is not valid JSON: {auth_path}: {exc}", file=sys.stderr)
        return 1
    key = data.get("api_key")
    if not isinstance(key, str) or not key.strip():
        print("OpenRouter API key not found in auth store", file=sys.stderr)
        return 1
    print(key.strip())
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
