#!/usr/bin/env python3
import json
import sys
from pathlib import Path

# Import shared helpers from the sibling module
sys.path.insert(0, str(Path(__file__).resolve().parent))
from codexswitch_common import user_home  # noqa: E402


def main() -> int:
    home = user_home()
    auth_path = home / ".config/codexswitch/opencode-go/auth.json"
    legacy_auth_path = home / ".local/share/opencode/auth.json"
    try:
        data = json.loads(auth_path.read_text())
    except FileNotFoundError:
        data = {}
    except json.JSONDecodeError as exc:
        print(f"OpenCode Go auth store is not valid JSON: {exc}", file=sys.stderr)
        return 1

    key = data.get("api_key") if isinstance(data, dict) else None
    if not key:
        try:
            legacy = json.loads(legacy_auth_path.read_text())
        except FileNotFoundError:
            legacy = {}
        except json.JSONDecodeError as exc:
            print(f"Legacy OpenCode auth is not valid JSON: {exc}", file=sys.stderr)
            return 1
        credential = legacy.get("opencode-go") or {}
        key = credential.get("key") if isinstance(credential, dict) else None
    if not key:
        print("OpenCode Go API key not found in CodexSwitch auth store", file=sys.stderr)
        return 1

    print(key)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
