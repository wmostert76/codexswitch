#!/usr/bin/env python3
"""Anthropic Messages compatibility handler for CodexSwitch providers."""

import hashlib
import json
import os
import time
import urllib.error
import urllib.request
from http.server import BaseHTTPRequestHandler
from urllib.parse import urlparse

from codexswitch_common import user_home

LOOPBACK = os.environ.get("CODEXSWITCH_PROVIDER_PROXY_URL", "http://127.0.0.1:14555")
MAX_REQUEST_BYTES = 32 * 1024 * 1024
OPENAI_IDENTIFIER_LIMIT = 64


def _short_identifier(value) -> str:
    value = str(value or "")
    if len(value) <= OPENAI_IDENTIFIER_LIMIT:
        return value
    digest = hashlib.sha256(value.encode()).hexdigest()[:16]
    prefix_length = OPENAI_IDENTIFIER_LIMIT - len(digest) - 1
    return f"{value[:prefix_length]}_{digest}"


def _tool_name_maps(body: dict) -> tuple[dict[str, str], dict[str, str]]:
    forward = {}
    reverse = {}
    for tool in body.get("tools") or []:
        if not isinstance(tool, dict) or not tool.get("name"):
            continue
        if str(tool.get("type", "")).startswith("web_search_"):
            continue
        original = str(tool["name"])
        shortened = _short_identifier(original)
        forward[original] = shortened
        reverse[shortened] = original
    return forward, reverse


def _text_content(block: dict, role: str) -> dict | None:
    kind = block.get("type")
    if kind == "text":
        return {"type": "output_text" if role == "assistant" else "input_text", "text": str(block.get("text", ""))}
    if kind == "image" and role == "user":
        source = block.get("source") or {}
        if source.get("type") == "base64":
            media = source.get("media_type", "image/png")
            return {"type": "input_image", "image_url": f"data:{media};base64,{source.get('data', '')}", "detail": "high"}
    return None


def _tool_result_output(content):
    if isinstance(content, dict):
        content = [content]
    if not isinstance(content, list):
        return str(content)
    output = []
    for part in content:
        if not isinstance(part, dict):
            output.append({"type": "input_text", "text": str(part)})
            continue
        if part.get("type") == "text":
            output.append({"type": "input_text", "text": str(part.get("text", ""))})
        elif part.get("type") == "image":
            source = part.get("source") or {}
            if source.get("type") == "base64" and source.get("data"):
                media = source.get("media_type", "image/png")
                output.append({
                    "type": "input_image",
                    "image_url": f"data:{media};base64,{source['data']}",
                    "detail": "high",
                })
        else:
            output.append({"type": "input_text", "text": json.dumps(part, separators=(",", ":"))})
    return output if output else ""


def messages_to_responses(body: dict) -> dict:
    items: list[dict] = []
    tool_names, _ = _tool_name_maps(body)
    system = body.get("system")
    if isinstance(system, list):
        instructions = "\n".join(str(block.get("text", "")) for block in system if isinstance(block, dict) and block.get("type") == "text")
    else:
        instructions = str(system or "")
    for message in body.get("messages") or []:
        if not isinstance(message, dict):
            continue
        role = message.get("role", "user")
        content = message.get("content", "")
        blocks = [{"type": "text", "text": content}] if isinstance(content, str) else content
        message_content = []

        def flush_message_content():
            if message_content:
                items.append({"type": "message", "role": role, "content": list(message_content)})
                message_content.clear()

        for block in blocks or []:
            if not isinstance(block, dict):
                continue
            converted = _text_content(block, role)
            if converted:
                message_content.append(converted)
            elif block.get("type") == "tool_use":
                flush_message_content()
                name = str(block.get("name", ""))
                items.append({
                    "type": "function_call",
                    "call_id": _short_identifier(block.get("id", "")),
                    "name": tool_names.get(name, _short_identifier(name)),
                    "arguments": json.dumps(block.get("input") or {}, separators=(",", ":")),
                })
            elif block.get("type") == "tool_result":
                flush_message_content()
                result = _tool_result_output(block.get("content", ""))
                items.append({"type": "function_call_output", "call_id": _short_identifier(block.get("tool_use_id", "")), "output": result})
            elif block.get("type") == "thinking" and role == "assistant":
                signature = str(block.get("signature") or "")
                if signature:
                    flush_message_content()
                    items.append({"type": "reasoning", "encrypted_content": signature, "summary": []})
        flush_message_content()
    tools = []
    has_web_search = False
    for tool in body.get("tools") or []:
        if not isinstance(tool, dict):
            continue
        if str(tool.get("type", "")).startswith("web_search_"):
            web_tool = {"type": "web_search"}
            allowed = tool.get("allowed_domains")
            if isinstance(allowed, list) and allowed:
                web_tool["filters"] = {"allowed_domains": allowed}
            location = tool.get("user_location")
            if isinstance(location, dict) and location:
                web_tool["user_location"] = location
            tools.append(web_tool)
            has_web_search = True
        elif tool.get("name"):
            name = str(tool["name"])
            tools.append({"type": "function", "name": tool_names.get(name, _short_identifier(name)), "description": tool.get("description", ""), "parameters": tool.get("input_schema") or {"type": "object", "properties": {}}})
    request = {
        "model": body.get("model"),
        "input": items,
        "stream": bool(body.get("stream")),
        "store": False,
        "max_output_tokens": body.get("max_tokens", 32000),
    }
    if instructions:
        request["instructions"] = instructions
    if tools:
        request["tools"] = tools
        tool_choice = body.get("tool_choice") or {"type": "auto"}
        if isinstance(tool_choice, str):
            tool_choice = {"type": tool_choice}
        choice_type = tool_choice.get("type") if isinstance(tool_choice, dict) else "auto"
        choice_name = str(tool_choice.get("name") or "") if isinstance(tool_choice, dict) else ""
        if choice_type == "tool" and has_web_search and choice_name == "web_search":
            request["tool_choice"] = {"type": "web_search"}
        elif choice_type == "tool" and choice_name:
            request["tool_choice"] = {
                "type": "function",
                "name": tool_names.get(choice_name, _short_identifier(choice_name)),
            }
        elif choice_type == "any":
            request["tool_choice"] = "required"
        elif choice_type == "none":
            request["tool_choice"] = "none"
        else:
            request["tool_choice"] = "auto"
        request["parallel_tool_calls"] = not bool(
            tool_choice.get("disable_parallel_tool_use", False)
            if isinstance(tool_choice, dict)
            else False
        )
    effort = os.environ.get("CODEXSWITCH_REASONING_EFFORT")
    if not effort:
        try:
            state = json.loads((user_home() / ".config/codexswitch/config.json").read_text())
            effort = state.get("reasoning_effort")
        except (OSError, json.JSONDecodeError, AttributeError):
            effort = None
    if effort:
        request["reasoning"] = {"effort": effort, "summary": "auto"}
        request["include"] = ["reasoning.encrypted_content"]
    return request


def responses_to_message(data: dict, model: str | None = None, tool_name_map: dict[str, str] | None = None) -> dict:
    tool_name_map = tool_name_map or {}
    citation_sources = []
    citation_titles = {}
    for item in data.get("output") or []:
        if not isinstance(item, dict) or item.get("type") != "message":
            continue
        for part in item.get("content") or []:
            if not isinstance(part, dict):
                continue
            for annotation in part.get("annotations") or []:
                if not isinstance(annotation, dict):
                    continue
                if annotation.get("type") != "url_citation":
                    continue
                url = str(annotation.get("url") or "")
                if url and url not in citation_titles:
                    title = str(annotation.get("title") or url)
                    citation_titles[url] = title
                    citation_sources.append({"type": "web_search_result", "title": title, "url": url})
    web_search_requests = sum(
        1
        for item in data.get("output") or []
        if isinstance(item, dict) and item.get("type") == "web_search_call"
    )
    content = []
    for item in data.get("output") or []:
        if not isinstance(item, dict):
            continue
        if item.get("type") == "reasoning":
            summary = item.get("summary") or item.get("content") or []
            if not isinstance(summary, list):
                summary = [summary]
            thinking = "".join(
                str(part.get("text", "")) if isinstance(part, dict) else str(part)
                for part in summary
            )
            signature = str(item.get("encrypted_content") or "")
            if thinking or signature:
                block = {"type": "thinking", "thinking": thinking}
                if signature:
                    block["signature"] = signature
                content.append(block)
        elif item.get("type") == "message":
            for part in item.get("content") or []:
                if isinstance(part, dict) and part.get("type") in {"output_text", "text"}:
                    content.append({"type": "text", "text": str(part.get("text", ""))})
        elif item.get("type") in {"function_call", "custom_tool_call"}:
            raw = item.get("arguments", item.get("input", "{}"))
            try:
                tool_input = json.loads(raw) if isinstance(raw, str) else raw
            except json.JSONDecodeError:
                tool_input = {"input": raw}
            tool_name = item.get("name", "")
            if tool_name == "Read" and isinstance(tool_input, dict) and tool_input.get("pages") == "":
                tool_input = dict(tool_input)
                tool_input.pop("pages")
            content.append({"type": "tool_use", "id": item.get("call_id") or item.get("id"), "name": tool_name_map.get(tool_name, tool_name), "input": tool_input or {}})
        elif item.get("type") == "web_search_call":
            action = item.get("action") or {}
            queries = action.get("queries") or []
            query = action.get("query") or (queries[0] if queries else "")
            tool_id = str(item.get("id") or f"srvtoolu_{int(time.time() * 1000)}")
            call_sources = []
            seen_call_urls = set()
            for source in action.get("sources") or []:
                if not isinstance(source, dict):
                    continue
                url = str(source.get("url") or "")
                if not url or url in seen_call_urls:
                    continue
                seen_call_urls.add(url)
                call_sources.append({
                    "type": "web_search_result",
                    "title": str(source.get("title") or citation_titles.get(url) or url),
                    "url": url,
                })
            if web_search_requests == 1:
                for source in citation_sources:
                    if source["url"] not in seen_call_urls:
                        call_sources.append(source)
            elif not call_sources:
                call_sources = list(citation_sources)
            content.append({"type": "server_tool_use", "id": tool_id, "name": "web_search", "input": {"query": str(query)}})
            content.append({"type": "web_search_tool_result", "tool_use_id": tool_id, "content": call_sources})
    if not content:
        text = data.get("output_text")
        content = [{"type": "text", "text": str(text or "")}]
    has_tools = any(block.get("type") == "tool_use" for block in content)
    usage = data.get("usage") or {}
    message_usage = {
        "input_tokens": int(usage.get("input_tokens", 0) or 0),
        "output_tokens": int(usage.get("output_tokens", 0) or 0),
    }
    if web_search_requests:
        message_usage["server_tool_use"] = {
            "web_search_requests": web_search_requests
        }
    cached_tokens = int(
        (usage.get("input_tokens_details") or {}).get("cached_tokens", 0) or 0
    )
    if cached_tokens:
        message_usage["cache_read_input_tokens"] = cached_tokens
    stop_reason = "tool_use" if has_tools else "end_turn"
    if not has_tools:
        reason = str(
            data.get("stop_reason")
            or (data.get("incomplete_details") or {}).get("reason")
            or ""
        )
        stop_reason = {
            "max_tokens": "max_tokens",
            "max_output_tokens": "max_tokens",
            "content_filter": "refusal",
            "refusal": "refusal",
            "model_context_window_exceeded": "model_context_window_exceeded",
        }.get(reason, "end_turn")
    return {
        "id": str(data.get("id") or f"msg_{int(time.time() * 1000)}"),
        "type": "message",
        "role": "assistant",
        "model": str(data.get("model") or model or ""),
        "content": content,
        "stop_reason": stop_reason,
        "stop_sequence": data.get("stop_sequence"),
        "usage": message_usage,
    }


class Handler(BaseHTTPRequestHandler):
    protocol_version = "HTTP/1.1"
    provider = ""

    def send_json(self, status: int, payload: dict) -> None:
        raw = json.dumps(payload).encode()
        self.send_response(status)
        self.send_header("content-type", "application/json")
        self.send_header("content-length", str(len(raw)))
        self.end_headers()
        self.wfile.write(raw)

    def sse(self, event: str, payload: dict) -> None:
        self.wfile.write(f"event: {event}\ndata: {json.dumps(payload)}\n\n".encode())

    def _stream_message(self, message: dict) -> None:
        self.send_response(200)
        self.send_header("content-type", "text/event-stream")
        self.send_header("cache-control", "no-cache")
        self.send_header("connection", "close")
        self.end_headers()
        start = {**message, "content": [], "stop_reason": None, "stop_sequence": None}
        self.sse("message_start", {"type": "message_start", "message": start})
        for index, block in enumerate(message["content"]):
            if block["type"] == "text":
                initial = {"type": "text", "text": ""}
            elif block["type"] == "thinking":
                initial = {"type": "thinking", "thinking": ""}
            elif block["type"] in {"tool_use", "server_tool_use"}:
                initial = {**block, "input": {}}
            else:
                initial = block
            self.sse("content_block_start", {"type": "content_block_start", "index": index, "content_block": initial})
            if block["type"] == "text":
                delta = {"type": "text_delta", "text": block.get("text", "")}
            elif block["type"] == "thinking":
                delta = {"type": "thinking_delta", "thinking": block.get("thinking", "")}
            elif block["type"] in {"tool_use", "server_tool_use"}:
                delta = {"type": "input_json_delta", "partial_json": json.dumps(block.get("input") or {}, separators=(",", ":"))}
            else:
                delta = None
            if delta is not None:
                self.sse("content_block_delta", {"type": "content_block_delta", "index": index, "delta": delta})
            if block["type"] == "thinking" and block.get("signature"):
                self.sse("content_block_delta", {
                    "type": "content_block_delta",
                    "index": index,
                    "delta": {"type": "signature_delta", "signature": block["signature"]},
                })
            self.sse("content_block_stop", {"type": "content_block_stop", "index": index})
        delta_usage = {"output_tokens": message["usage"]["output_tokens"]}
        if message["usage"].get("server_tool_use"):
            delta_usage["server_tool_use"] = message["usage"]["server_tool_use"]
        self.sse("message_delta", {"type": "message_delta", "delta": {"stop_reason": message["stop_reason"], "stop_sequence": message.get("stop_sequence")}, "usage": delta_usage})
        self.sse("message_stop", {"type": "message_stop"})
        self.wfile.flush()
        self.close_connection = True

    def _stream_responses(self, upstream, body: dict, tool_name_map: dict[str, str]) -> None:
        self.send_response(200)
        self.send_header("content-type", "text/event-stream")
        self.send_header("cache-control", "no-cache")
        self.send_header("connection", "close")
        self.end_headers()

        model = str(body.get("model") or "")
        message_id = f"msg_{int(time.time() * 1000)}"
        started = False
        next_block = 0
        open_block = None
        pending_calls = {}
        emitted_tools = False
        web_search_requests = 0
        thinking_text_seen = False

        def start_message(response=None):
            nonlocal started, message_id, model
            if started:
                return
            response = response or {}
            message_id = str(response.get("id") or message_id)
            model = str(response.get("model") or model)
            self.sse("message_start", {
                "type": "message_start",
                "message": {
                    "id": message_id,
                    "type": "message",
                    "role": "assistant",
                    "model": model,
                    "content": [],
                    "stop_reason": None,
                    "stop_sequence": None,
                    "usage": {"input_tokens": 0, "output_tokens": 0},
                },
            })
            started = True

        def close_block():
            nonlocal open_block
            if open_block is not None:
                self.sse("content_block_stop", {
                    "type": "content_block_stop",
                    "index": open_block[1],
                })
                open_block = None

        def open_text():
            nonlocal next_block, open_block
            start_message()
            if open_block and open_block[0] == "text":
                return open_block[1]
            close_block()
            index = next_block
            next_block += 1
            self.sse("content_block_start", {
                "type": "content_block_start",
                "index": index,
                "content_block": {"type": "text", "text": ""},
            })
            open_block = ("text", index)
            return index

        def open_thinking():
            nonlocal next_block, open_block
            start_message()
            if open_block and open_block[0] == "thinking":
                return open_block[1]
            close_block()
            index = next_block
            next_block += 1
            self.sse("content_block_start", {
                "type": "content_block_start",
                "index": index,
                "content_block": {"type": "thinking", "thinking": ""},
            })
            open_block = ("thinking", index)
            return index

        def emit_tool(item):
            nonlocal next_block, emitted_tools
            close_block()
            start_message()
            index = next_block
            next_block += 1
            call_id = str(item.get("call_id") or item.get("id") or "")
            name = str(item.get("name") or "")
            name = tool_name_map.get(name, name)
            arguments = item.get("arguments") or "{}"
            if not isinstance(arguments, str):
                arguments = json.dumps(arguments, separators=(",", ":"))
            self.sse("content_block_start", {
                "type": "content_block_start",
                "index": index,
                "content_block": {"type": "tool_use", "id": call_id, "name": name, "input": {}},
            })
            self.sse("content_block_delta", {
                "type": "content_block_delta",
                "index": index,
                "delta": {"type": "input_json_delta", "partial_json": arguments},
            })
            self.sse("content_block_stop", {"type": "content_block_stop", "index": index})
            emitted_tools = True

        def emit_web_search(item):
            nonlocal next_block, web_search_requests
            close_block()
            start_message()
            translated = responses_to_message({"output": [item]}, model)
            web_search_requests += 1
            for block in translated["content"]:
                index = next_block
                next_block += 1
                self.sse("content_block_start", {
                    "type": "content_block_start",
                    "index": index,
                    "content_block": ({**block, "input": {}} if block["type"] == "server_tool_use" else block),
                })
                if block["type"] == "server_tool_use":
                    self.sse("content_block_delta", {
                        "type": "content_block_delta",
                        "index": index,
                        "delta": {"type": "input_json_delta", "partial_json": json.dumps(block.get("input") or {}, separators=(",", ":"))},
                    })
                self.sse("content_block_stop", {"type": "content_block_stop", "index": index})

        terminal = None
        for raw_line in upstream:
            line = raw_line.decode(errors="replace").strip()
            if not line.startswith("data:"):
                continue
            payload = line[5:].strip()
            if not payload or payload == "[DONE]":
                continue
            try:
                event = json.loads(payload)
            except json.JSONDecodeError:
                continue
            event_type = event.get("type")
            if event_type == "response.created":
                start_message(event.get("response") or {})
            elif event_type == "response.reasoning_summary_text.delta":
                thinking_text_seen = True
                index = open_thinking()
                self.sse("content_block_delta", {
                    "type": "content_block_delta",
                    "index": index,
                    "delta": {"type": "thinking_delta", "thinking": str(event.get("delta") or "")},
                })
            elif event_type == "response.output_text.delta":
                index = open_text()
                self.sse("content_block_delta", {
                    "type": "content_block_delta",
                    "index": index,
                    "delta": {"type": "text_delta", "text": str(event.get("delta") or "")},
                })
            elif event_type == "response.output_item.added":
                item = event.get("item") or {}
                if item.get("type") == "function_call":
                    pending_calls[event.get("output_index")] = item
            elif event_type == "response.function_call_arguments.delta":
                key = event.get("output_index")
                pending = pending_calls.setdefault(key, {"type": "function_call"})
                pending["arguments"] = str(pending.get("arguments") or "") + str(event.get("delta") or "")
            elif event_type == "response.output_item.done":
                item = event.get("item") or {}
                item_type = item.get("type")
                if item_type == "function_call":
                    pending = pending_calls.pop(event.get("output_index"), {})
                    merged = {**pending, **item}
                    if pending.get("arguments") and not item.get("arguments"):
                        merged["arguments"] = pending["arguments"]
                    emit_tool(merged)
                elif item_type == "reasoning":
                    summary = item.get("summary") or item.get("content") or []
                    if not isinstance(summary, list):
                        summary = [summary]
                    if not thinking_text_seen:
                        for part in summary:
                            text = str(part.get("text", "")) if isinstance(part, dict) else str(part)
                            if text:
                                index = open_thinking()
                                self.sse("content_block_delta", {
                                    "type": "content_block_delta",
                                    "index": index,
                                    "delta": {"type": "thinking_delta", "thinking": text},
                                })
                    if item.get("encrypted_content"):
                        index = open_thinking()
                        self.sse("content_block_delta", {
                            "type": "content_block_delta",
                            "index": index,
                            "delta": {"type": "signature_delta", "signature": item["encrypted_content"]},
                        })
                    close_block()
                    thinking_text_seen = False
                elif item_type == "web_search_call":
                    emit_web_search(item)
                elif item_type == "message" and not open_block:
                    for part in item.get("content") or []:
                        if part.get("type") == "output_text" and part.get("text"):
                            index = open_text()
                            self.sse("content_block_delta", {
                                "type": "content_block_delta",
                                "index": index,
                                "delta": {"type": "text_delta", "text": str(part["text"])},
                            })
            elif event_type in {"response.completed", "response.incomplete"}:
                terminal = event.get("response") or {}
            elif event_type in {"error", "response.failed"}:
                raise RuntimeError(json.dumps(event.get("error") or event, ensure_ascii=False)[:2000])

        start_message(terminal or {})
        close_block()
        terminal = terminal or {}
        usage = terminal.get("usage") or {}
        delta_usage = {"output_tokens": int(usage.get("output_tokens", 0) or 0)}
        cached_tokens = int((usage.get("input_tokens_details") or {}).get("cached_tokens", 0) or 0)
        if cached_tokens:
            delta_usage["cache_read_input_tokens"] = cached_tokens
        if web_search_requests:
            delta_usage["server_tool_use"] = {"web_search_requests": web_search_requests}
        terminal_message = responses_to_message({**terminal, "output": []}, model)
        stop_reason = "tool_use" if emitted_tools else terminal_message["stop_reason"]
        self.sse("message_delta", {
            "type": "message_delta",
            "delta": {"stop_reason": stop_reason, "stop_sequence": terminal_message.get("stop_sequence")},
            "usage": delta_usage,
        })
        self.sse("message_stop", {"type": "message_stop"})
        self.wfile.flush()
        self.close_connection = True

    def do_POST(self):
        if urlparse(self.path).path not in {"/messages", "/v1/messages"}:
            self.send_json(404, {"type": "error", "error": {"type": "not_found_error", "message": "not found"}})
            return
        try:
            length = int(self.headers.get("content-length", "0"))
            if length < 0 or length > MAX_REQUEST_BYTES:
                raise ValueError("request body too large")
            body = json.loads(self.rfile.read(length) or b"{}")
            request = messages_to_responses(body)
            target = f"{LOOPBACK}/{self.provider}/v1/responses"
            upstream = urllib.request.Request(target, data=json.dumps(request).encode(), headers={"content-type": "application/json"}, method="POST")
            with urllib.request.urlopen(upstream, timeout=300) as response:
                _, reverse_tool_names = _tool_name_maps(body)
                content_type = response.headers.get("content-type", "")
                if body.get("stream") and "text/event-stream" in content_type:
                    try:
                        self._stream_responses(response, body, reverse_tool_names)
                    except (BrokenPipeError, ConnectionResetError):
                        return
                    except Exception as exc:
                        try:
                            self.sse("error", {
                                "type": "error",
                                "error": {"type": "api_error", "message": str(exc)[:2000]},
                            })
                            self.wfile.flush()
                            self.close_connection = True
                        except (BrokenPipeError, ConnectionResetError):
                            pass
                    return
                result = json.loads(response.read())
            message = responses_to_message(result, body.get("model"), reverse_tool_names)
            if body.get("stream"):
                self._stream_message(message)
            else:
                self.send_json(200, message)
        except (BrokenPipeError, ConnectionResetError):
            return
        except Exception as exc:
            detail = str(exc)
            if isinstance(exc, urllib.error.HTTPError):
                try:
                    detail = exc.read().decode(errors="replace")[:2000] or detail
                except Exception:
                    pass
            try:
                self.send_json(502, {"type": "error", "error": {"type": "api_error", "message": detail}})
            except (BrokenPipeError, ConnectionResetError):
                return
