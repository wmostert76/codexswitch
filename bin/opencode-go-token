#!/usr/bin/env python3
import json
import sys
from pathlib import Path

# Import shared helpers from the sibling module
sys.path.insert(0, str(Path(__file__).resolve().parent))
from codexswitch_common import user_home  # noqa: E402


def main() -> int:
    auth_path = user_home() / ".local/share/opencode/auth.json"
    try:
        data = json.loads(auth_path.read_text())
    except FileNotFoundError:
        print(f"OpenCode auth not found: {auth_path}", file=sys.stderr)
        return 1
    except json.JSONDecodeError as exc:
        print(f"OpenCode auth is not valid JSON: {auth_path}: {exc}", file=sys.stderr)
        return 1

    credential = data.get("opencode-go") or {}
    key = credential.get("key")
    if not key:
        print("OpenCode Go API key not found in OpenCode auth store", file=sys.stderr)
        return 1

    print(key)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
