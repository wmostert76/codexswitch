from textual.binding import Binding
from textual.containers import Horizontal, Vertical
from textual.screen import ModalScreen
from textual.widgets import Button, Header, Input, Label, OptionList, Static
from textual.widgets.option_list import Option

from textual.events import Click


PROJECT = Path(__file__).resolve().parents[1]
BACKEND_PATH = PROJECT / "bin/codexswitch"
BACKEND = runpy.run_path(str(BACKEND_PATH))

FKEY_ACTIONS = {
    "1": "help",
    "2": "accounts",
    "3": "models",
    "4": "reasoning",
    "5": "refresh",
    "6": "apply",
    "7": "auth",
    "8": "status",
    "9": "codex",
    "10": "quit",
}
CODEX_TUI_LAUNCH_ARGS = (
    "resume",
    "--dangerously-bypass-approvals-and-sandbox",
    "--search",
)
DEFAULT_REASONING_VALUE = "__default__"
FUNCTION_KEYS = (
    ("1", "Help"),
    ("2", "Prov"),
    ("3", "Model"),
    ("4", "Think"),
    ("5", "Fresh"),
    ("6", "Apply"),
    ("7", "Auth"),
    ("8", "Stat"),
    ("9", "Codex"),
    ("10", "Quit"),
)



class FKey(Static):
    """A clickable function-key label styled like Midnight Commander."""

    def __init__(self, *args, action: str = "", **kwargs) -> None:
        super().__init__(*args, **kwargs)
        self.fkey_action = action


def splash_line(text: str) -> str:
    return text.center(BACKEND["ASCII_LOGO_WIDTH"])


class SplashScreen(ModalScreen):
    BINDINGS = [
        ("enter", "dismiss", "Continue"),
        ("escape", "dismiss", "Continue"),
        ("space", "dismiss", "Continue"),
    ]

    def compose(self) -> ComposeResult:
        yield Static(
            f"""[bold white]{BACKEND['BRAND_BANNER']}[/]

[bold white]{splash_line(f"CodexSwitch Commander v{BACKEND['VERSION']}")}[/]
[black]{splash_line(BACKEND['CREDITS_OWNER'])}[/]
[black]{splash_line(BACKEND['CREDITS_AI'])}[/]

[black]{splash_line("Enter / Space / Esc / Click to continue")}[/]
""",
            id="splash-dialog",
            markup=True,
        )

    def on_click(self, event: Click) -> None:
        self.dismiss()


class HelpScreen(ModalScreen):
    BINDINGS = [("escape", "dismiss", "Close"), ("f1", "dismiss", "Close")]

    def compose(self) -> ComposeResult:
        yield Static(
            """
[bold white]CODEXSWITCH COMMANDER HELP[/]

[black]NAVIGATION[/]
  Tab · Shift+Tab   Switch panel
  ↑ ↓               Move selection
  Enter on model    Move to reasoning
  Enter on reason   Apply and start Codex

FUNCTION KEYS
  F1  Help          This screen
  F2  Providers     Focus provider/account panel
  F3  Models        Focus model panel
  F4  Reasoning     Focus reasoning modes
  F5  Refresh       Refresh OpenCode Go catalog
  F6  Apply         Activate selection without starting Codex
  F7  Auth          Login to selected provider
  F8  Status        Reload active configuration
  F9  Codex         Resume Codex with bypass sandbox and search
  F10 Quit          Close CodexSwitch

[black]Press Escape, F1 or click to close.[/]
""",
            id="help-dialog",
            markup=True,
        )

    def on_click(self, event: Click) -> None:
        self.dismiss()


class OpenAIAuthScreen(ModalScreen):
    BINDINGS = [
        ("enter", "start", "Start"),
        ("escape", "dismiss", "Cancel"),
    ]

    def compose(self) -> ComposeResult:
        yield Static(
            """
[bold white]OPENAI DEVICE SIGN-IN[/]

[black]
Open the activation page when Codex shows the device code:

  [bold white]https://chatgpt.com/activate[/]

CodexSwitch will temporarily leave the TUI and start:

  codex login --device-auth

Codex will show the current device code. Enter that code on the page,
finish login, then return here. When Codex reports the login is complete,
CodexSwitch verifies ~/.codex/auth.json, saves the account and refreshes
the provider/account list.

[bold white]Enter[/] Start sign-in    [bold white]Esc[/] Cancel
""",
            id="openai-auth-dialog",
            markup=True,
        )

    def action_start(self) -> None:
        self.dismiss()
        self.app.run_openai_device_auth()


class ApiKeyScreen(ModalScreen):
    BINDINGS = [
        ("escape", "dismiss", "Cancel"),
    ]

    def __init__(self, provider: str):
        super().__init__()
        self.provider = provider
        self.provider_label = {
            "opencode-go": "OpenCode Go",
            "openrouter": "OpenRouter",
        }[provider]

    def compose(self) -> ComposeResult:
        yield Static(
            f"[bold white]{self.provider_label.upper()} API KEY[/]\n\n"
            "[black]Paste the API key below. It is stored in the CodexSwitch "
            "secret store with 0600 file permissions.[/]",
            id="api-key-title",
            markup=True,
        )
        yield Input(password=True, placeholder=f"{self.provider_label} API key", id="api-key-input")
        yield Button("Save / Renew", id="api-key-save", variant="primary")
        yield Button("Cancel", id="api-key-cancel")

    def on_mount(self) -> None:
        self.query_one("#api-key-input", Input).focus()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "api-key-cancel":
            self.dismiss()
            return
        key = self.query_one("#api-key-input", Input).value.strip()
        if not key:
            self.app.set_status(f"{self.provider_label} API key is empty", error=True)
            return
        self.dismiss(key)

    def on_input_submitted(self, event: Input.Submitted) -> None:
        key = event.value.strip()
        if not key:
            self.app.set_status(f"{self.provider_label} API key is empty", error=True)
            return
        self.dismiss(key)

class CodexSwitchApp(App):
    TITLE = "CodexSwitch Commander"
    SUB_TITLE = f"v{BACKEND['VERSION']} · {BACKEND['CREDITS_OWNER']}"

    CSS = """
