class ApiKeyScreen(ModalScreen[str | None]):
    BINDINGS = [Binding("escape", "cancel", "Cancel", show=False)]

    def __init__(self, provider: str) -> None:
        super().__init__()
        self.provider = provider
        self.provider_label = PROVIDER_LABELS[provider]

    def compose(self) -> ComposeResult:
        with Vertical(classes="modal-dialog", id="api-key-dialog"):
            yield Label(
                f"{self.provider_label.upper()} API KEY",
                classes="modal-title",
            )
            yield Static(
                "The key is stored in the encrypted CodexSwitch vault.",
                classes="modal-copy",
            )
            yield Label("API key", classes="field-label")
            yield Input(
                password=True,
                placeholder=f"{self.provider_label} API key",
                id="api-key-input",
                classes="form-input",
            )
            yield Label("", id="form-error", classes="form-error")
            with Horizontal(classes="modal-actions"):
                yield Button("Save / Renew", id="api-key-save", variant="primary")
                yield Button("Cancel", id="api-key-cancel")

    def on_mount(self) -> None:
        self.query_one("#api-key-input", Input).focus()

    def action_cancel(self) -> None:
        self.dismiss(None)

    def submit(self) -> None:
        field = self.query_one("#api-key-input", Input)
        key = field.value.strip()
        if not key:
            self.query_one("#form-error", Label).update("API key is required")
            field.focus()
            return
        self.dismiss(key)

    def on_input_submitted(self, event: Input.Submitted) -> None:
        self.submit()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "api-key-cancel":
            self.dismiss(None)
        else:
            self.submit()


class AzureAuthScreen(ModalScreen[tuple[str, str] | None]):
    BINDINGS = [Binding("escape", "cancel", "Cancel", show=False)]

    def __init__(self, endpoint: str) -> None:
        super().__init__()
        self.endpoint = endpoint

    def compose(self) -> ComposeResult:
        with Vertical(classes="modal-dialog", id="azure-dialog"):
            yield Label("AZURE OPENAI CREDENTIALS", classes="modal-title")
            yield Static(
                "Credentials are stored in the encrypted CodexSwitch vault.",
                classes="modal-copy",
            )
            yield Label("Endpoint", classes="field-label")
            yield Input(
                value=self.endpoint,
                placeholder="https://…",
                id="azure-endpoint-input",
                classes="form-input",
            )
            yield Label("API key", classes="field-label")
            yield Input(
                password=True,
                placeholder="Azure API key",
                id="api-key-input",
                classes="form-input",
            )
            yield Label("", id="form-error", classes="form-error")
            with Horizontal(classes="modal-actions"):
                yield Button("Save / Renew", id="api-key-save", variant="primary")
                yield Button("Cancel", id="api-key-cancel")

    def on_mount(self) -> None:
        self.query_one("#azure-endpoint-input", Input).focus()

    def action_cancel(self) -> None:
        self.dismiss(None)

    def on_input_submitted(self, event: Input.Submitted) -> None:
        if event.input.id == "azure-endpoint-input":
            self.query_one("#api-key-input", Input).focus()
        else:
            self.submit()

    def on_button_pressed(self, event: Button.Pressed) -> None:
        if event.button.id == "api-key-cancel":
            self.dismiss(None)
        else:
            self.submit()

    def submit(self) -> None:
        endpoint_field = self.query_one("#azure-endpoint-input", Input)
        key_field = self.query_one("#api-key-input", Input)
        error = self.query_one("#form-error", Label)
        endpoint = endpoint_field.value.strip()
        key = key_field.value.strip()
        if not endpoint:
            error.update("Endpoint is required")
            endpoint_field.focus()
            return
        if not key:
            error.update("API key is required")
            key_field.focus()
            return
        self.dismiss((endpoint, key))


